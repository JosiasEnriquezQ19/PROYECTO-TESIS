<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notificaciones - CARSIL</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            theme: { extend: {
                colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                fontFamily: { "display": ["Inter", "sans-serif"] },
            }}
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .main-content { padding: 0 !important; background: #f6f6f8; }
        .notification-item.unread { border-left: 3px solid #3b82f6; }
        .notification-item:hover { background-color: #f1f5f9 !important; }
    </style>
</head>
<body class="bg-[#f6f6f8] text-slate-900 font-display">
<div class="wrapper">
    <%- include('../parciales/sidebar') %>
    <div class="main-content" id="main-content">
        <div class="p-8">

        <!-- Page Title -->
                <div class="mb-8 flex items-end justify-between">
                    <div>
                        <h2 class="text-2xl font-bold text-slate-900 mb-1">Notificaciones</h2>
                        <p class="text-slate-500 text-sm">Centro de actividad y alertas recientes del sistema</p>
                    </div>
                    <div>
                        <button onclick="marcarTodasLeidas()"
                            class="inline-flex items-center gap-2 bg-[#3b4bc9] hover:bg-[#2f3db0] text-white font-semibold text-sm px-4 py-2 rounded-xl transition-colors shadow-sm">
                            <i class="bi bi-check2-all text-base"></i>
                            Marcar todas como leídas
                        </button>
                    </div>
                </div>

                <!-- Alertas Flash -->
                <% if (error && error.length> 0) { %>
                    <div class="alert"
                        style="background-color: #fef2f2; color: #dc2626; padding: 1rem; border-radius: 0.5rem; border-left: 4px solid #dc2626; margin-bottom: 1.5rem; font-weight: 500;">
                        <i class="bi bi-exclamation-triangle-fill" style="margin-right: 0.5rem;"></i>
                        <%= error %>
                    </div>
                    <% } %>

                        <% if (success && success.length> 0) { %>
                            <div class="alert alert-success"
                                style="background-color: #f0fdf4; color: #16a34a; padding: 1rem; border-radius: 0.5rem; border-left: 4px solid #16a34a; margin-bottom: 1.5rem; font-weight: 500;">
                                <i class="bi bi-check-circle-fill" style="margin-right: 0.5rem;"></i>
                                <%= success %>
                            </div>
                            <% } %>

                                <!-- Lista de notificaciones -->
                                <div class="card"
                                    style="background: white; border-radius: 1rem; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -2px rgba(0, 0, 0, 0.05); border: 1px solid rgba(0,0,0,0.05); overflow: hidden;">

                                    <% if (notificaciones && notificaciones.length> 0) { %>
                                        <div class="notifications-list" style="display: flex; flex-direction: column;">

                                            <% notificaciones.forEach(notif=> { %>
                                                <div class="notification-item <%= !notif.Leida ? 'unread' : '' %>"
                                                    style="padding: 1.25rem 1.5rem; border-bottom: 1px solid #f1f5f9; display: flex; gap: 1rem; align-items: flex-start; transition: all 0.2s; <%= !notif.Leida ? 'background-color: #f8fafc;' : '' %>"
                                                    id="notif-<%= notif.IdNotificacion %>">

                                                    <!-- Icono segun operacion -->
                                                    <div class="notif-icon-container"
                                                        style="flex-shrink: 0; width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;
                                <%= notif.Tipo === 'CREAR' ? 'background-color: #dcfce7; color: #16a34a;' : 
                                    (notif.Tipo === 'ACTUALIZAR' ? 'background-color: #dbeafe; color: #2563eb;' : 
                                    (notif.Tipo === 'ELIMINAR' ? 'background-color: #fee2e2; color: #dc2626;' : 'background-color: #f1f5f9; color: #64748b;')) %>">

                                                        <i class="bi <%= notif.Tipo === 'CREAR' ? 'bi-plus-circle' : 
                                               (notif.Tipo === 'ACTUALIZAR' ? 'bi-pencil-square' : 
                                               (notif.Tipo === 'ELIMINAR' ? 'bi-trash' : 'bi-info-circle')) %>"></i>
                                                    </div>

                                                    <!-- Contenido -->
                                                    <div class="notif-content" style="flex: 1; min-width: 0;">
                                                        <div
                                                            style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.25rem;">
                                                            <h5
                                                                style="margin: 0; font-size: 0.95rem; font-weight: <%= !notif.Leida ? '700' : '600' %>; color: #0f172a;">
                                                                <%= notif.Mensaje %>
                                                            </h5>

                                                            <span class="notif-time"
                                                                style="font-size: 0.75rem; color: #64748b; font-weight: 500; white-space: nowrap; margin-left: 1rem;">
                                                                <% const fecha=new Date(notif.FechaCreacion); const
                                                                    formatDate=fecha.toLocaleDateString('es-ES', {
                                                                    day: '2-digit' , month: 'short' , year: 'numeric'
                                                                    }); const
                                                                    formatTime=fecha.toLocaleTimeString('es-ES', {
                                                                    hour: '2-digit' , minute: '2-digit' }); %>
                                                                    <%= formatDate %> a las <%= formatTime %>
                                                            </span>
                                                        </div>

                                                        <% if (notif.Detalle) { %>
                                                            <p
                                                                style="margin: 0.25rem 0 0 0; font-size: 0.875rem; color: #475569; line-height: 1.4;">
                                                                <strong>Detalle:</strong>
                                                                <%= notif.Detalle %>
                                                            </p>
                                                            <% } %>

                                                                <% if (notif.Usuario) { %>
                                                                    <p
                                                                        style="margin: 0.25rem 0 0 0; font-size: 0.8rem; color: #64748b; display: inline-flex; align-items: center; gap: 0.25rem; background-color: #f1f5f9; padding: 2px 8px; border-radius: 99px; margin-top: 0.5rem;">
                                                                        <i class="bi bi-person"></i>
                                                                        <%= notif.Usuario %>
                                                                    </p>
                                                                    <% } %>
                                                    </div>

                                                    <!-- Botones Accion -->
                                                    <% if (!notif.Leida) { %>
                                                        <div class="notif-actions"
                                                            style="flex-shrink: 0; margin-left: auto;">
                                                            <button onclick="marcarLeida('<%= notif.IdNotificacion %>')"
                                                                class="btn-leida"
                                                                style="background: none; border: none; color: #2563eb; font-size: 0.8rem; font-weight: 600; cursor: pointer; padding: 0.25rem 0.5rem; border-radius: 0.25rem; transition: background 0.2s;"
                                                                onmouseover="this.style.backgroundColor='#dbeafe'"
                                                                onmouseout="this.style.backgroundColor='transparent'"
                                                                title="Marcar como leída">
                                                                <i class="bi bi-check-circle"
                                                                    style="font-size: 1rem;"></i>
                                                            </button>
                                                        </div>
                                                        <% } %>

                                                </div>
                                                <% }) %>
                                        </div>
                                        <% } else { %>
                                            <div class="empty-state" style="padding: 4rem 2rem; text-align: center;">
                                                <div class="empty-icon"
                                                    style="width: 80px; height: 80px; border-radius: 50%; background-color: #f1f5f9; color: #94a3b8; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; margin: 0 auto 1.5rem;">
                                                    <i class="bi bi-bell-slash"></i>
                                                </div>
                                                <h3
                                                    style="margin: 0 0 0.5rem 0; font-size: 1.25rem; font-weight: 700; color: #1e293b;">
                                                    No hay notificaciones</h3>
                                                <p style="margin: 0; color: #64748b; font-size: 0.95rem;">Estás al día.
                                                    El sistema no tiene nuevas alertas registradas.</p>
                                            </div>
                                            <% } %>

                                </div>
        </div><!-- /p-8 -->
    </div><!-- /main-content -->
</div><!-- /wrapper -->

    <script>
        async function marcarLeida(id) {
            try {
                const response = await fetch(`/api/notificaciones/leer/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();

                if (data.ok) {
                    // Actualizar interfaz visual
                    const notifEl = document.getElementById(`notif-${id}`);
                    notifEl.classList.remove('unread');
                    notifEl.style.backgroundColor = 'transparent';
                    notifEl.style.borderLeft = 'none';

                    const titleEl = notifEl.querySelector('h5');
                    titleEl.style.fontWeight = '600';

                    const btnEl = notifEl.querySelector('.btn-leida');
                    if (btnEl) btnEl.remove();

                    // Actualizar badge superior
                    const badge = document.getElementById('notificacionBadge');
                    if (badge) {
                        let text = badge.innerText.replace('+', '');
                        let num = parseInt(text) - 1;
                        if (num <= 0) {
                            badge.style.display = 'none';
                        } else {
                            badge.innerText = num > 99 ? '+99' : num;
                        }
                    }
                }
            } catch (error) {
                console.error('Error al marcar notificación:', error);
            }
        }

        async function marcarTodasLeidas() {
            try {
                const response = await fetch('/api/notificaciones/leer-todas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();

                if (data.ok) {
                    // Actualizar todas las de la lista
                    document.querySelectorAll('.notification-item.unread').forEach(el => {
                        el.classList.remove('unread');
                        el.style.backgroundColor = 'transparent';
                        el.style.borderLeft = 'none';

                        const titleEl = el.querySelector('h5');
                        titleEl.style.fontWeight = '600';

                        const btnEl = el.querySelector('.btn-leida');
                        if (btnEl) btnEl.remove();
                    });

                    // Ocultar badge superior
                    const badge = document.getElementById('notificacionBadge');
                    if (badge) badge.style.display = 'none';
                }
            } catch (error) {
                console.error('Error al marcar todas:', error);
            }
        }
    </script>
</body>
</html>