<!-- Sidebar - Estilo Linear/Notion Minimalista -->
<nav class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <div class="brand-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
                <rect width="28" height="28" rx="8" fill="var(--primary, #3B49DF)" />
                <path d="M8 10h12M8 14h8M8 18h10" stroke="#fff" stroke-width="2" stroke-linecap="round" />
            </svg>
        </div>
        <div class="brand-text">
            <span class="brand-name">CARSIL</span>
            <span class="brand-sub">Gestión de Proformas</span>
        </div>
        <button class="toggle-btn" id="toggleSidebarBtn" title="Ocultar menú" style="margin-left: auto;">
            <i class="bi bi-layout-sidebar-inset"></i>
        </button>
    </div>

    <div class="sidebar-section-label">MENÚ</div>

    <div class="sidebar-nav">
        <a href="/menu/principal" class="sidebar-item" data-page="inicio">
            <i class="bi bi-grid-1x2"></i>
            <span>Dashboard</span>
        </a>

        <% if (user && tienePermiso(user, 'proformas' )) { %>
            <a href="/proformas" class="sidebar-item" data-page="proformas">
                <i class="bi bi-file-earmark-text"></i>
                <span>Proformas</span>
            </a>
            <% } %>

                <% if (user && tienePermiso(user, 'facturas' )) { %>
                    <a href="/facturas" class="sidebar-item" data-page="facturas">
                        <i class="bi bi-receipt"></i>
                        <span>Facturas</span>
                    </a>
                    <% } %>

                        <% if (user && tienePermiso(user, 'clientes' )) { %>
                            <a href="/clientes" class="sidebar-item" data-page="clientes">
                                <i class="bi bi-people"></i>
                                <span>Clientes</span>
                            </a>
                            <% } %>

                                <% if (user && tienePermiso(user, 'productos' )) { %>
                                    <a href="/productos" class="sidebar-item" data-page="productos">
                                        <i class="bi bi-box"></i>
                                        <span>Productos</span>
                                    </a>
                                    <% } %>

                                        <div class="sidebar-section-label">RECURSOS HUMANOS</div>

                                        <% if (user && tienePermiso(user, 'empleados' )) { %>
                                            <a href="/empleados" class="sidebar-item" data-page="empleados">
                                                <i class="bi bi-person-badge"></i>
                                                <span>Empleados</span>
                                            </a>
                                            <% } %>

                                                <% if (user && tienePermiso(user, 'pagos' )) { %>
                                                    <a href="/pagos" class="sidebar-item" data-page="pagos">
                                                        <i class="bi bi-wallet2"></i>
                                                        <span>Pagos</span>
                                                    </a>
                                                    <% } %>

                                                        <% if (user && tienePermiso(user, 'asistencias' )) { %>
                                                            <a href="/asistencia" class="sidebar-item"
                                                                data-page="asistencias">
                                                                <i class="bi bi-calendar-check"></i>
                                                                <span>Asistencias</span>
                                                            </a>
                                                            <% } %>

                                                                <div class="sidebar-section-label">ADMINISTRACIÓN</div>

                                                                <% if (user && tienePermiso(user, 'reportes' )) { %>
                                                                    <a href="/reportes" class="sidebar-item"
                                                                        data-page="reportes">
                                                                        <i class="bi bi-bar-chart-line"></i>
                                                                        <span>Reportes</span>
                                                                    </a>
                                                                    <% } %>

                                                                        <% if (user && tienePermiso(user, 'usuarios' ))
                                                                            { %>
                                                                            <a href="/usuarios" class="sidebar-item"
                                                                                data-page="usuarios">
                                                                                <i class="bi bi-shield-check"></i>
                                                                                <span>Usuarios</span>
                                                                            </a>
                                                                            <% } %>

                                                                                <% if (user &&
                                                                                    tienePermiso(user, 'empresa' )) { %>
                                                                                    <a href="/empresa"
                                                                                        class="sidebar-item"
                                                                                        data-page="empresa">
                                                                                        <i class="bi bi-gear"></i>
                                                                                        <span>Empresa</span>
                                                                                    </a>
                                                                                    <% } %>
