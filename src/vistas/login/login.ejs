<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ingreso | CARSIL Equipos y Servicios</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-color: #003366;
            --secondary-color: #0077b6;
            --accent-color: #FF6B00;
            --light-gray: #f8f9fa;
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            min-height: 100vh;
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?ixlib=rb-4.0.3') center/cover no-repeat fixed;
        }
        .main-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }
        .content-wrapper {
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1.5rem;
        }
        .overlay {
            position: fixed;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 51, 102, 0.7);
            top: 0;
            left: 0;
            z-index: -1;
        }
        .auth-container {
            max-width: 500px;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            padding: 2.5rem;
            color: #232323;
        }
        .brand-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .brand-logo {
            height: 80px;
            width: auto;
            max-width: 100%;
            margin-bottom: 1rem;
        }
        .auth-title {
            color: var(--primary-color);
            margin-bottom: 2rem;
            font-weight: 700;
            font-size: 1.75rem;
            text-align: center;
        }
        .form-label {
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: var(--primary-color);
            font-size: 0.95rem;
        }
        .input-group-text {
            background: var(--primary-color);
            color: white;
            border: 1px solid var(--primary-color);
            min-width: 45px;
            display: flex;
            justify-content: center;
        }
        .form-control {
            padding: 0.75rem 1rem;
            border-radius: 0 8px 8px 0;
            border: 1px solid #ced4da;
            border-left: none;
            transition: all 0.3s;
            font-size: 1rem;
        }
        .form-control:focus {
            border-color: var(--primary-color);
            box-shadow: 0 0 0 0.25rem rgba(0, 51, 102, 0.15);
            border-left: none;
        }
        .input-group:focus-within .input-group-text {
            border-color: var(--primary-color);
        }
        .btn-login {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            border: none;
            padding: 0.85rem;
            font-weight: 600;
            font-size: 1.1rem;
            border-radius: 10px;
            transition: all 0.3s;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 51, 102, 0.4);
            background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
        }
        .btn-login:active {
            transform: translateY(0);
        }
        .forgot-password {
            color: var(--secondary-color);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.2s;
        }
        .forgot-password:hover {
            color: var(--primary-color);
            text-decoration: underline;
        }
        .footer {
            color: #fff;
            text-align: center;
            font-size: 0.85rem;
            opacity: 0.95;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
            padding: 0 1rem;
        }
        .password-toggle {
            background: transparent;
            border: none;
            cursor: pointer;
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #6c757d;
            z-index: 10;
            padding: 0.5rem;
        }
        .password-toggle:hover {
            color: var(--primary-color);
        }
        .password-input-group {
            position: relative;
        }
        .alert {
            border-radius: 10px;
            border: none;
            font-size: 0.95rem;
        }
        
        /* Responsive para móvil */
        @media (max-width: 576px) {
            .main-wrapper {
                padding: 1rem 0.5rem;
            }
            .auth-container {
                padding: 2rem 1.5rem;
                border-radius: 12px;
            }
            .brand-logo {
                height: 60px;
            }
            .auth-title {
                font-size: 1.4rem;
                margin-bottom: 1.5rem;
            }
            .form-label {
                font-size: 0.9rem;
            }
            .form-control {
                padding: 0.65rem 0.85rem;
                font-size: 0.95rem;
            }
            .input-group-text {
                min-width: 40px;
                font-size: 0.9rem;
            }
            .btn-login {
                padding: 0.75rem;
                font-size: 1rem;
            }
            .forgot-password {
                font-size: 0.85rem;
            }
            .footer {
                font-size: 0.75rem;
            }
            .password-toggle {
                right: 10px;
                padding: 0.4rem;
            }
        }
        
        /* Tablets */
        @media (min-width: 577px) and (max-width: 768px) {
            .auth-container {
                padding: 2.25rem 2rem;
            }
            .brand-logo {
                height: 70px;
            }
            .auth-title {
                font-size: 1.6rem;
            }
        }
        
        /* Landscape móvil */
        @media (max-height: 600px) and (orientation: landscape) {
            body {
            .main-wrapperpadding: 0.5rem;
            }
            .auth-container {
                padding: 1.5rem;
                max-width: 600px;
            }
            .brand-logo {
                height: 50px;
                margin-bottom: 0.5rem;
            }
            .auth-title {
                font-size: 1.3rem;
                margin-bottom: 1rem;
            }
            .content-wrapper {
                gap: 0.75rem;
            }
        }
    </style>
</head>
<body>
    <div class="overlay"></div>
    <div class="main-wrapper">
        <div class="content-wrapper">
            <div style="max-width: 500px; width: 100%;">
                <div class="auth-container">
                    <div class="brand-header">
                        <img src="/img/Carsil.png" alt="Logo CARSIL" class="brand-logo">
                    </div>
                    <h2 class="auth-title">Acceso al Sistema</h2>
                    <% if (error) { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i><%= error %>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    <% } %>
                    <form method="POST" action="/login" autocomplete="off">
                        <div class="mb-3">
                            <label for="correo" class="form-label">Correo electrónico</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input type="email" class="form-control" id="correo" name="correo" required autofocus placeholder="usuario@dominio.com">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label for="clave" class="form-label">Contraseña</label>
                            <div class="password-input-group">
                                <div class="input-group">
                                    <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                    <input type="password" class="form-control" id="clave" name="clave" required placeholder="••••••••">
                                </div>
                                <button type="button" class="password-toggle" id="togglePassword">
                                    <i class="far fa-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-login btn-primary">
                                <i class="fas fa-sign-in-alt me-2"></i> Ingresar
                            </button>
                        </div>
                        <div class="text-center">
                            <a href="/recuperar" class="forgot-password">
                                <i class="fas fa-key me-1"></i> ¿Olvidaste tu contraseña?
                            </a>
                        </div>
                    </form>
                </div>
            </div>
            <div class="footer">
                &copy; <%= new Date().getFullYear() %> CARSIL Equipos y Servicios. Todos los derechos reservados.
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Mostrar/Ocultar contraseña
        document.getElementById('togglePassword').addEventListener('click', function() {
            const passwordInput = document.getElementById('clave');
            const icon = this.querySelector('i');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            }
        });
    </script>
</body>
</html>