<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - CARSIL</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { 
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(135deg, #003366 0%, #0056b3 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .marcar-container {
            background: white;
            border-radius: 2rem;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            padding: 3rem;
            max-width: 800px;
            width: 100%;
        }
        .header-section {
            text-align: center;
            margin-bottom: 2.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 3px solid #003366;
        }
        .company-logo {
            font-size: 2.5rem;
            font-weight: 700;
            color: #003366;
            margin-bottom: 0.5rem;
        }
        .company-tagline {
            color: #666;
            font-size: 0.95rem;
        }
        .fecha-hora {
            background: linear-gradient(135deg, #f8f9fa, #e9ecef);
            padding: 2rem;
            border-radius: 1.5rem;
            text-align: center;
            margin-bottom: 2rem;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
        }
        .fecha-display {
            font-size: 1.8rem;
            font-weight: 600;
            color: #003366;
            margin-bottom: 0.5rem;
        }
        .hora-display {
            font-size: 3rem;
            font-weight: 700;
            color: #0056b3;
            font-family: 'Courier New', monospace;
        }
        .dia-semana {
            font-size: 1.2rem;
            color: #666;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        .empleado-info {
            background: linear-gradient(135deg, #003366, #0056b3);
            color: white;
            padding: 1.5rem;
            border-radius: 1rem;
            margin-bottom: 2rem;
            text-align: center;
        }
        .empleado-nombre {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.3rem;
        }
        .empleado-cargo {
            font-size: 1rem;
            opacity: 0.9;
        }
        .botones-marcado {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        .btn-marcar {
            padding: 2rem;
            font-size: 1.3rem;
            font-weight: 600;
            border-radius: 1.5rem;
            border: none;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.8rem;
        }
        .btn-marcar i {
            font-size: 3rem;
        }
        .btn-entrada {
            background: linear-gradient(135deg, #28a745, #20c997);
            color: white;
        }
        .btn-entrada:hover:not(:disabled) {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(40,167,69,0.4);
        }
        .btn-salida {
            background: linear-gradient(135deg, #dc3545, #c82333);
            color: white;
        }
        .btn-salida:hover:not(:disabled) {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(220,53,69,0.4);
        }
        .btn-marcar:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        .estado-actual {
            background: #f8f9fa;
            padding: 1.5rem;
            border-radius: 1rem;
            margin-bottom: 2rem;
        }
        .estado-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.8rem;
            margin-bottom: 0.5rem;
        }
        .estado-label {
            font-weight: 600;
            color: #333;
        }
        .estado-valor {
            font-size: 1.2rem;
            font-weight: 700;
            color: #0056b3;
        }
        .historial-section {
            margin-top: 2.5rem;
            padding-top: 2rem;
            border-top: 2px solid #e9ecef;
        }
        .historial-title {
            font-size: 1.3rem;
            font-weight: 600;
            color: #003366;
            margin-bottom: 1rem;
        }
        .historial-table {
            font-size: 0.9rem;
        }
        .badge-presente {
            background: linear-gradient(135deg, #28a745, #20c997);
        }
        .btn-cerrar-sesion {
            width: 100%;
            padding: 1rem;
            font-size: 1.1rem;
            font-weight: 600;
            background: linear-gradient(135deg, #6c757d, #495057);
            border: none;
            border-radius: 1rem;
            color: white;
            margin-top: 1.5rem;
        }
        .btn-cerrar-sesion:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(108,117,125,0.3);
        }
        .alert-domingo {
            background: linear-gradient(135deg, #ffc107, #ff9800);
            color: #fff;
            border: none;
            border-radius: 1rem;
            padding: 1.5rem;
            text-align: center;
            font-weight: 600;
            font-size: 1.1rem;
        }
        @media (max-width: 768px) {
            .botones-marcado {
                grid-template-columns: 1fr;
            }
            .marcar-container {
                padding: 2rem 1.5rem;
            }
        }
    </style>
</head>
<body>
    <div class="marcar-container">
        <!-- Header -->
        <div class="header-section">
            <div class="company-logo">CARSIL</div>
            <div class="company-tagline">Equipos y Servicios SAC</div>
        </div>

        <!-- Mensajes -->
        <% if (messages.success && messages.success.length > 0) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                <%= messages.success[0] %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        <% if (messages.error && messages.error.length > 0) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <%= messages.error[0] %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <!-- Información del Empleado -->
        <div class="empleado-info">
            <div class="empleado-nombre">
                <i class="bi bi-person-circle me-2"></i>
                <%= empleado.NombreCompleto %>
            </div>
            <div class="empleado-cargo">
                <%= empleado.Cargo %> - <%= empleado.Area || 'Sin área' %>
            </div>
        </div>

        <!-- Fecha y Hora Actual -->
        <div class="fecha-hora">
            <div class="dia-semana" id="diaSemana"></div>
            <div class="fecha-display" id="fechaDisplay"></div>
            <div class="hora-display" id="horaDisplay"></div>
        </div>

        <% if (esDomingo) { %>
            <!-- Alerta de Domingo -->
            <div class="alert-domingo">
                <i class="bi bi-calendar-x me-2"></i>
                No hay marcado de asistencia los domingos
            </div>
        <% } else { %>
            <!-- Estado Actual del Día -->
            <% if (registroHoy) { %>
                <div class="estado-actual">
                    <h5 class="text-center mb-3" style="color: #003366; font-weight: 600;">
                        <i class="bi bi-clock-history me-2"></i>
                        Registro de Hoy
                    </h5>
                    <div class="estado-item">
                        <span class="estado-label">
                            <i class="bi bi-box-arrow-in-right text-success me-2"></i>Entrada:
                        </span>
                        <span class="estado-valor text-success">
                            <%= registroHoy.HoraEntrada ? registroHoy.HoraEntrada.slice(0,5) : '--:--' %>
                        </span>
                    </div>
                    <div class="estado-item">
                        <span class="estado-label">
                            <i class="bi bi-box-arrow-right text-danger me-2"></i>Salida:
                        </span>
                        <span class="estado-valor <%= registroHoy.HoraSalida ? 'text-danger' : 'text-muted' %>">
                            <%= registroHoy.HoraSalida ? registroHoy.HoraSalida.slice(0,5) : '--:--' %>
                        </span>
                    </div>
                    <% if (registroHoy.HorasTrabajadas) { %>
                        <div class="estado-item">
                            <span class="estado-label">
                                <i class="bi bi-hourglass-split text-primary me-2"></i>Horas Trabajadas:
                            </span>
                            <span class="estado-valor text-primary">
                                <%= registroHoy.HorasTrabajadas %> hrs
                            </span>
                        </div>
                    <% } %>
                </div>
            <% } %>

            <!-- Botones de Marcado -->
            <div class="botones-marcado">
                <form action="/asistencia/marcar-entrada" method="POST" style="margin: 0;">
                    <button type="submit" 
                            class="btn btn-entrada btn-marcar w-100" 
                            <%= registroHoy ? 'disabled' : '' %>>
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>MARCAR ENTRADA</span>
                    </button>
                </form>
                
                <form action="/asistencia/marcar-salida" method="POST" style="margin: 0;">
                    <button type="submit" 
                            class="btn btn-salida btn-marcar w-100"
                            <%= !registroHoy || registroHoy.HoraSalida ? 'disabled' : '' %>>
                        <i class="bi bi-box-arrow-right"></i>
                        <span>MARCAR SALIDA</span>
                    </button>
                </form>
            </div>
        <% } %>

        <!-- Historial Reciente -->
        <% if (historialReciente && historialReciente.length > 0) { %>
            <div class="historial-section">
                <h5 class="historial-title">
                    <i class="bi bi-calendar-week me-2"></i>
                    Últimos 7 Días
                </h5>
                <div class="table-responsive">
                    <table class="table table-hover historial-table">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha</th>
                                <th>Entrada</th>
                                <th>Salida</th>
                                <th>Horas</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% historialReciente.forEach(registro => { 
                                const fecha = new Date(registro.Fecha);
                                const fechaFormat = fecha.toLocaleDateString('es-PE', { 
                                    day: '2-digit', 
                                    month: '2-digit', 
                                    year: 'numeric' 
                                });
                            %>
                                <tr>
                                    <td><%= fechaFormat %></td>
                                    <td class="text-success fw-bold">
                                        <%= registro.HoraEntrada ? registro.HoraEntrada.slice(0,5) : '--:--' %>
                                    </td>
                                    <td class="text-danger fw-bold">
                                        <%= registro.HoraSalida ? registro.HoraSalida.slice(0,5) : '--:--' %>
                                    </td>
                                    <td class="text-primary fw-bold">
                                        <%= registro.HorasTrabajadas || '0' %> hrs
                                    </td>
                                    <td>
                                        <span class="badge badge-presente">
                                            <%= registro.Estado %>
                                        </span>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        <% } %>

        <!-- Botón Cerrar Sesión -->
        <a href="/logout" class="btn btn-cerrar-sesion">
            <i class="bi bi-box-arrow-left me-2"></i>
            Cerrar Sesión
        </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Actualizar fecha y hora en tiempo real
        function actualizarFechaHora() {
            const ahora = new Date();
            
            // Día de la semana
            const dias = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
            document.getElementById('diaSemana').textContent = dias[ahora.getDay()];
            
            // Fecha
            const opciones = { day: '2-digit', month: 'long', year: 'numeric' };
            document.getElementById('fechaDisplay').textContent = 
                ahora.toLocaleDateString('es-PE', opciones);
            
            // Hora
            const horas = String(ahora.getHours()).padStart(2, '0');
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const segundos = String(ahora.getSeconds()).padStart(2, '0');
            document.getElementById('horaDisplay').textContent = 
                `${horas}:${minutos}:${segundos}`;
        }
        
        // Actualizar cada segundo
        actualizarFechaHora();
        setInterval(actualizarFechaHora, 1000);
    </script>
</body>
</html>
