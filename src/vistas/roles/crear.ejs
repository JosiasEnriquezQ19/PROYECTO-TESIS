<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crear Rol - CARSIL Equipos y Servicios SAC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css">
    <style>
@media (max-width: 768px) {
}
/* Estilos mejorados para el formulario */
        .form-container {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
            padding: 2.5rem;
            margin-bottom: 2rem;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }
        .form-title {
            color: #003366;
            font-weight: 700;
            margin-bottom: 1.5rem;
            position: relative;
            padding-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .form-title:after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 50px;
            height: 4px;
            background: linear-gradient(90deg, #0056b3, #00a1ff);
            border-radius: 2px;
        }
        .form-title i {
            font-size: 1.5rem;
            color: #0056b3;
        }
        .form-label {
            font-weight: 600;
            color: #495057;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .form-label i {
            font-size: 0.9rem;
            color: #6c757d;
        }
        .form-control {
            border-radius: 8px;
            padding: 0.75rem 1rem;
            border: 1px solid #e0e0e0;
            transition: all 0.3s;
        }
        .form-control:focus {
            border-color: #0056b3;
            box-shadow: 0 0 0 0.25rem rgba(0, 86, 179, 0.15);
        }
        .btn-primary {
            background-color: #0056b3;
            border-color: #0056b3;
            border-radius: 8px;
            padding: 0.625rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s;
        }
        .btn-primary:hover {
            background-color: #004494;
            border-color: #004494;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 86, 179, 0.2);
        }
        .btn-secondary {
            border-radius: 8px;
            padding: 0.625rem 1.5rem;
            font-weight: 600;
            transition: all 0.3s;
        }
        .btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(108, 117, 125, 0.1);
        }
        .alert {
            border-radius: 8px;
            padding: 1rem;
        }
        .navbar {
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
        }
        .navbar-brand {
            font-weight: 600;
            color: #003366;
        }
        .form-text {
            font-size: 0.85rem;
            color: #6c757d;
            margin-top: 0.25rem;
        }
        .permissions-section {
            margin-top: 2rem;
            border-top: 1px solid #eee;
            padding-top: 1.5rem;
        }
        .permissions-title {
            font-weight: 600;
            color: #003366;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .permission-card {
            background: #f8fafc;
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
            border: 1px solid #e9ecef;
        }
        .permission-group {
            font-weight: 600;
            color: #495057;
            margin-bottom: 0.75rem;
        }
        .form-check {
            margin-bottom: 0.5rem;
        }
        .form-check-input:checked {
            background-color: #0056b3;
            border-color: #0056b3;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <%- include("../parciales/sidebar") %>
        <!-- Botón para ocultar/mostrar barra -->
        <!-- Main Content -->
        <div class="main-content" id="main-content">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
                <div class="container-fluid">
                    <span class="navbar-brand ms-3">Panel de Control</span>
                    <div class="user-profile ms-auto">
                        <span>Administrador</span>
                        <div class="user-avatar">A</div>
                    </div>
                </div>
            </nav>
            <div class="container-fluid py-4">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="form-container">
                            <h2 class="form-title">
                                <i class="bi bi-shield-lock"></i>
                                Crear Nuevo Rol
                            </h2>
                            
                            <% if (messages.error && messages.error.length > 0) { %>
                                <div class="alert alert-danger alert-dismissible fade show">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    <%= messages.error[0] %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            <% } %>
                            <% if (messages.success && messages.success.length > 0) { %>
                                <div class="alert alert-success alert-dismissible fade show">
                                    <i class="bi bi-check-circle-fill me-2"></i>
                                    <%= messages.success[0] %>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            <% } %>
                            
                            <form action="/roles/crear" method="POST">
                                <div class="mb-4">
                                    <label for="nombre" class="form-label">
                                        <i class="bi bi-tag"></i>
                                        Nombre del Rol
                                    </label>
                                    <input type="text" class="form-control" id="nombre" name="nombre" required placeholder="Ej: Administrador, Supervisor, etc.">
                                    <div class="form-text">Ingrese un nombre único para identificar este rol</div>
                                </div>
                                
                                <div class="mb-4">
                                    <label for="descripcion" class="form-label">
                                        <i class="bi bi-text-paragraph"></i>
                                        Descripción
                                    </label>
                                    <textarea class="form-control" id="descripcion" name="descripcion" rows="4" style="min-height: 100px;" placeholder="Describa las funciones y responsabilidades de este rol"></textarea>
                                    <div class="form-text">Esta descripción ayudará a entender el propósito del rol</div>
                                </div>
                                
                                <!-- Sección de permisos (puedes descomentar si necesitas incluir permisos) -->
                                <!--
                                <div class="permissions-section">
                                    <h5 class="permissions-title">
                                        <i class="bi bi-key"></i>
                                        Asignar Permisos
                                    </h5>
                                    
                                    <div class="permission-card">
                                        <div class="permission-group">Módulo Usuarios</div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="create-user">
                                            <label class="form-check-label" for="create-user">Crear usuarios</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="edit-user">
                                            <label class="form-check-label" for="edit-user">Editar usuarios</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="delete-user">
                                            <label class="form-check-label" for="delete-user">Eliminar usuarios</label>
                                        </div>
                                    </div>
                                    
                                    <div class="permission-card">
                                        <div class="permission-group">Módulo Clientes</div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="create-client">
                                            <label class="form-check-label" for="create-client">Crear clientes</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="edit-client">
                                            <label class="form-check-label" for="edit-client">Editar clientes</label>
                                        </div>
                                    </div>
                                </div>
                                -->
                                
                                <div class="d-flex justify-content-between align-items-center mt-5">
                                    <a href="/roles" class="btn btn-secondary">
                                        <i class="bi bi-arrow-left me-2"></i>Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-save me-2"></i>Guardar Rol
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const toggleBtn = document.getElementById('toggleSidebarBtn');
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('main-content');
        const toggleIcon = document.getElementById('toggleIcon');
        const menuItems = document.querySelectorAll('.menu-item');
        const userAvatar = document.querySelector('.user-avatar');
        const userName = 'Administrador';
        userAvatar.textContent = userName.charAt(0);

        toggleBtn.addEventListener('click', function() {
            sidebar.classList.toggle('hide');
            mainContent.classList.toggle('full');
            if (sidebar.classList.contains('hide')) {
                toggleIcon.classList.remove('bi-chevron-left');
                toggleIcon.classList.add('bi-chevron-right');
            } else {
                toggleIcon.classList.remove('bi-chevron-right');
                toggleIcon.classList.add('bi-chevron-left');
            }
        });});
    </script>
    <script src="/publico/js/layout.js"></script>
</body>
</html>
