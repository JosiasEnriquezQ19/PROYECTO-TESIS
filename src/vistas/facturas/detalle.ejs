<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Factura <%= factura.Codigo %> - CARSIL ERP</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#3b4bc9",
                        "background-light": "#f6f6f8",
                        "background-dark": "#13151f",
                    },
                    fontFamily: {
                        "display": ["Inter"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        /* PDF specific styles */
        .pdf-mode {
            background: white !important;
        }

        .pdf-mode .hide-on-print {
            display: none !important;
        }

        .pdf-mode #factura-print-area {
            box-shadow: none !important;
            border: none !important;
            margin: 0 !important;
            padding: 20px !important;
            max-width: none !important;
        }

        .pdf-mode * {
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        /* Estilos base para la vista general */
        body {
            background-color: theme('colors.background-light');
        }

        @media (prefers-color-scheme: dark) {
            body {
                background-color: theme('colors.background-dark');
            }
        }
    </style>
</head>

<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 min-h-screen">
    <%# Helper local declarations para parseo seguro %>
        <% var fSubtotal=!isNaN(parseFloat(factura.SubTotal)) ? parseFloat(factura.SubTotal).toFixed(2) : '0.00' ; var
            fIgv=!isNaN(parseFloat(factura.TotalIGV)) ? parseFloat(factura.TotalIGV).toFixed(2) : '0.00' ; var
            fTotal=!isNaN(parseFloat(factura.Total)) ? parseFloat(factura.Total).toFixed(2) : '0.00' ; var
            fFechaEmision=factura.FechaEmision ? (factura.FechaEmision.toISOString ?
            factura.FechaEmision.toISOString().split('T')[0] : factura.FechaEmision) : new
            Date().toISOString().split('T')[0]; var fFechaVenc=factura.FechaVencimiento ?
            (factura.FechaVencimiento.toISOString ? factura.FechaVencimiento.toISOString().split('T')[0] :
            factura.FechaVencimiento) : '-' ; var clInfo=cliente || {}; var empInfo=empresa || {}; var usInfo=usuario ||
            {}; var estadoLower=(factura.Estado || 'pendiente' ).toLowerCase(); var isPagada=estadoLower==='pagada' ; %>

            <div class="relative flex h-auto min-h-screen w-full flex-col group/design-root overflow-x-hidden">
                <div class="layout-container flex h-full grow flex-col">

                    <!-- Top Navigation Bar (Manteniendo el estilo Tailwind) -->
                    <header
                        class="flex items-center justify-between whitespace-nowrap border-b border-solid border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 px-10 py-3 sticky top-0 z-50 hide-on-print shadow-sm">
                        <div class="flex items-center gap-8">
                            <div class="flex items-center gap-3">
                                <img src="/img/Carsil.png" alt="CARSIL Logo" class="h-8 object-contain"
                                    onerror="this.style.display='none'">
                            </div>
                        </div>
                        <div class="flex flex-1 justify-end gap-3">
                            <a href="/facturas"
                                class="flex items-center justify-center rounded-lg h-10 px-4 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 font-medium text-sm transition-colors">
                                <span class="material-symbols-outlined text-[18px] mr-2">arrow_back</span>
                                Volver a Lista
                            </a>
                        </div>
                    </header>

                    <main class="flex-1 overflow-y-auto">
                        <div class="max-w-[1024px] mx-auto px-4 sm:px-10 py-8" id="document-content">

                            <!-- Breadcrumbs & Actions -->
                            <div
                                class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-6 gap-4 hide-on-print">
                                <div class="flex items-center gap-2 text-sm">
                                    <a class="text-slate-500 hover:text-primary transition-colors"
                                        href="/dashboard">Dashboard</a>
                                    <span
                                        class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
                                    <a class="text-slate-500 hover:text-primary transition-colors"
                                        href="/facturas">Facturas</a>
                                    <span
                                        class="material-symbols-outlined text-[16px] text-slate-400">chevron_right</span>
                                    <span class="text-slate-900 dark:text-slate-100 font-semibold">
                                        <%= factura.Codigo %>
                                    </span>
                                </div>
                                <div class="flex gap-3 w-full sm:w-auto" id="action-buttons-group">
                                    <button onclick="generatePDF()" id="btnDownloadPdf"
                                        class="flex-1 sm:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 transition-colors shadow-sm">
                                        <span class="material-symbols-outlined text-[18px]">download</span> PDF
                                    </button>
                                    <button onclick="window.print()"
                                        class="flex-1 sm:flex-none flex items-center justify-center gap-2 px-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 transition-colors shadow-sm">
                                        <span class="material-symbols-outlined text-[18px]">print</span> Imprimir
                                    </button>
                                </div>
                            </div>

                            <!-- Main Document Container (Print Ready Style) -->
                            <div class="bg-white dark:bg-slate-900 shadow-xl border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden p-8 sm:p-12 mb-10"
                                id="factura-print-area">

                                <!-- Header: Company Info & Proforma ID -->
                                <div
                                    class="flex flex-col md:flex-row justify-between gap-8 pb-8 border-b border-slate-100 dark:border-slate-800">
                                    <div class="flex gap-6 items-start">
                                        <div class="rounded-lg max-w-[120px]">
                                            <img src="/img/Carsil.png" alt="Logo Empresa" class="w-full object-contain"
                                                onerror="this.style.display='none'">
                                        </div>
                                        <div>
                                            <div
                                                class="text-[11px] text-slate-500 font-medium uppercase tracking-wider mb-1">
                                                RUC: <%= empInfo.Ruc || '20539958013' %>
                                            </div>
                                            <p class="text-sm text-slate-500 dark:text-slate-400">
                                                <%= empInfo.Direccion || '-' %>
                                            </p>
                                            <p class="text-sm text-slate-500 dark:text-slate-400">
                                                <%= empInfo.Telefono || '-' %> | <%= empInfo.Email || '-' %>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="text-right flex flex-col items-end">
                                        <div
                                            class="bg-blue-50 dark:bg-blue-900/20 px-4 py-2 rounded-lg border border-blue-100 dark:border-blue-800 mb-3 text-center min-w-[180px]">
                                            <p
                                                class="text-blue-800 dark:text-blue-300 text-[10px] font-black tracking-widest uppercase mb-1">
                                                FACTURA ELECTRÓNICA</p>
                                            <p class="text-blue-600 dark:text-blue-400 text-xl font-bold font-mono">
                                                <%= factura.Codigo %>
                                            </p>
                                        </div>

                                        <% let badgeColor=isPagada
                                            ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' :
                                            (estadoLower==='anulada'
                                            ? 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400'
                                            : 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400' );
                                            %>
                                            <span
                                                class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider <%= badgeColor %> mb-2">
                                                <%= factura.Estado || 'PENDIENTE' %>
                                            </span>

                                            <div class="text-[11px] text-slate-500 text-right mt-1">
                                                <span class="font-semibold text-slate-700 dark:text-slate-300">Fecha
                                                    Emisión:</span>
                                                <%= fFechaEmision %>
                                            </div>
                                            <div class="text-[11px] text-slate-500 text-right">
                                                <span
                                                    class="font-semibold text-slate-700 dark:text-slate-300">Vencimiento:</span>
                                                <%= fFechaVenc %>
                                            </div>
                                    </div>
                                </div>

                                <!-- Customer & Invoice Meta Info -->
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 py-8">
                                    <div class="space-y-4">
                                        <h3
                                            class="text-xs font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 dark:border-slate-800 pb-2">
                                            Datos del Cliente</h3>
                                        <div>
                                            <p class="font-bold text-slate-800 dark:text-slate-100 text-base mb-1">
                                                <%= clInfo.RazonSocial || 'Cliente General' %>
                                            </p>
                                            <div class="text-sm text-slate-500 space-y-1">
                                                <p><span
                                                        class="font-medium text-slate-700 dark:text-slate-300">RUC/DNI:</span>
                                                    <%= clInfo.Documento || '-' %>
                                                </p>
                                                <p><span
                                                        class="font-medium text-slate-700 dark:text-slate-300">Dirección:</span>
                                                    <%= clInfo.Direccion || '-' %>
                                                </p>
                                                <p><span
                                                        class="font-medium text-slate-700 dark:text-slate-300">Contacto:</span>
                                                    <%= clInfo.Contacto || '-' %>
                                                </p>
                                                <p><span
                                                        class="font-medium text-slate-700 dark:text-slate-300">Email:</span>
                                                    <%= clInfo.Email || '-' %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="space-y-4">
                                        <h3
                                            class="text-xs font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 dark:border-slate-800 pb-2">
                                            Detalles de Facturación</h3>
                                        <div
                                            class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-4 text-sm text-slate-600 dark:text-slate-400 space-y-2">
                                            <div class="flex justify-between">
                                                <span class="font-medium text-slate-700 dark:text-slate-300">Forma de
                                                    Pago:</span>
                                                <span>
                                                    <%= factura.FormaPago || 'CONTADO' %>
                                                </span>
                                            </div>
                                            <% if (factura.IdProforma) { %>
                                                <div class="flex justify-between">
                                                    <span class="font-medium text-slate-700 dark:text-slate-300">Modo de
                                                        Generación:</span>
                                                    <span>Desde Proforma</span>
                                                </div>
                                                <% } %>
                                                    <% if (empresa && empresa.CuentaBancaria) { %>
                                                        <div
                                                            class="flex flex-col mt-2 pt-2 border-t border-slate-200 dark:border-slate-700">
                                                            <span
                                                                class="font-medium text-slate-700 dark:text-slate-300 mb-1">Cuenta
                                                                de Abono:</span>
                                                            <span class="font-mono text-xs">
                                                                <%= empresa.NombreCuentaBancaria || 'CARSIL' %>
                                                            </span>
                                                            <span class="font-mono text-xs font-bold">
                                                                <%= empresa.CuentaBancaria %>
                                                            </span>
                                                        </div>
                                                        <% } %>
                                                            <% if (factura.Observaciones) { %>
                                                                <div
                                                                    class="flex justify-between mt-2 pt-2 border-t border-slate-200 dark:border-slate-700">
                                                                    <span
                                                                        class="font-medium text-slate-700 dark:text-slate-300 block w-full">Observaciones:
                                                                        <span class="font-normal text-slate-500 italic">
                                                                            <%= factura.Observaciones %>
                                                                        </span></span>
                                                                </div>
                                                                <% } %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Products Table -->
                                <div class="py-4">
                                    <table class="w-full text-left border-collapse">
                                        <thead>
                                            <tr
                                                class="border-y border-slate-200 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-800/50">
                                                <th
                                                    class="py-3 px-4 text-[11px] font-black text-slate-500 uppercase tracking-wider text-center w-12">
                                                    Item</th>
                                                <th
                                                    class="py-3 px-4 text-[11px] font-black text-slate-500 uppercase tracking-wider w-20 text-center">
                                                    Cant.</th>
                                                <th
                                                    class="py-3 px-4 text-[11px] font-black text-slate-500 uppercase tracking-wider w-20 text-center">
                                                    Unid.</th>
                                                <th
                                                    class="py-3 px-4 text-[11px] font-black text-slate-500 uppercase tracking-wider">
                                                    Descripción</th>
                                                <th
                                                    class="py-3 px-4 text-[11px] font-black text-slate-500 uppercase tracking-wider text-right w-28">
                                                    P. Unit.</th>
                                                <th
                                                    class="py-3 px-4 text-[11px] font-black text-slate-500 uppercase tracking-wider text-right w-32">
                                                    Subtotal</th>
                                            </tr>
                                        </thead>
                                        <tbody class="text-sm divide-y divide-slate-100 dark:divide-slate-800">
                                            <% if (productos && productos.length> 0) { %>
                                                <% productos.forEach(function(item, index) { var
                                                    pUnit=!isNaN(parseFloat(item.PrecioUnitario)) ?
                                                    parseFloat(item.PrecioUnitario).toFixed(2) : '0.00' ; var
                                                    pTot=!isNaN(parseFloat(item.Total)) ?
                                                    parseFloat(item.Total).toFixed(2) : '0.00' ; var bgClass=index %
                                                    2===1 ? 'bg-slate-50/30 dark:bg-slate-800/20' : '' ; %>
                                                    <tr class="<%= bgClass %>">
                                                        <td class="py-4 px-4 font-bold text-slate-400 text-center">
                                                            <%= String(index + 1).padStart(2, '0' ) %>
                                                        </td>
                                                        <td class="py-4 px-4 font-bold text-center">
                                                            <%= item.Cantidad || 1 %>
                                                        </td>
                                                        <td class="py-4 px-4 text-slate-500 text-center text-xs">
                                                            <%= item.UnidadMedida || item.Unidad || 'UND' %>
                                                        </td>
                                                        <td class="py-4 px-4">
                                                            <p class="font-bold text-slate-800 dark:text-slate-200">
                                                                <%= item.ProductoNombre || item.Nombre
                                                                    || 'Producto / Servicio' %>
                                                            </p>
                                                            <% if (item.ProductoDescripcion || item.Descripcion) { %>
                                                                <p
                                                                    class="text-xs text-slate-500 mt-1 line-clamp-2 print:line-clamp-none">
                                                                    <%= item.ProductoDescripcion || item.Descripcion %>
                                                                </p>
                                                                <% } %>
                                                        </td>
                                                        <td
                                                            class="py-4 px-4 text-right font-medium text-slate-600 dark:text-slate-400">
                                                            <%= pUnit %>
                                                        </td>
                                                        <td
                                                            class="py-4 px-4 text-right font-black text-slate-900 dark:text-white">
                                                            <%= pTot %>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                                        <% } else { %>
                                                            <tr>
                                                                <td colspan="6"
                                                                    class="py-8 text-center text-slate-500 bg-slate-50/50">
                                                                    <span
                                                                        class="material-symbols-outlined text-4xl mb-2 text-slate-300">inventory_2</span>
                                                                    <p>No hay productos registrados en esta factura</p>
                                                                </td>
                                                            </tr>
                                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Totals & QR Section -->
                                <div class="flex flex-col lg:flex-row justify-between items-start gap-8 pt-6">

                                    <!-- QR Representación Impresa -->
                                    <div
                                        class="w-full lg:w-1/2 flex items-center gap-4 bg-slate-50 dark:bg-slate-800/30 p-4 rounded-xl border border-slate-100 dark:border-slate-800">
                                        <div class="bg-white p-2 rounded-lg shadow-sm border border-slate-200 shrink-0">
                                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=20539958013|01|<%= factura.Codigo %>|<%= fFechaEmision %>|<%= fTotal %>"
                                                alt="Código QR SUNAT" class="w-20 h-20 opacity-80 mix-blend-multiply">
                                        </div>
                                        <div class="text-xs text-slate-500 space-y-1">
                                            <p class="font-bold text-slate-700 dark:text-slate-300 uppercase">
                                                Representación Impresa Factura Electrónica</p>
                                            <p>Autorizado mediante resolución de SUNAT.</p>
                                            <p class="mt-1">Hash: <span
                                                    class="font-mono bg-slate-200 dark:bg-slate-700 px-1 py-0.5 rounded text-[9px] break-all">xQwertyABChashGenerico+1234=</span>
                                            </p>
                                            <p>Consulte su documento en <a href="https://www.sunat.gob.pe"
                                                    class="text-primary hover:underline">www.sunat.gob.pe</a></p>
                                        </div>
                                    </div>

                                    <!-- Totals -->
                                    <div class="w-full lg:w-72 space-y-2 lg:mt-0 lg:ml-auto">
                                        <div class="flex justify-between px-3 py-1">
                                            <span class="text-sm text-slate-500 font-medium">Sub-total:</span>
                                            <span class="text-sm font-bold text-slate-700 dark:text-slate-300">S/ <%=
                                                    fSubtotal %></span>
                                        </div>
                                        <div class="flex justify-between px-3 py-1">
                                            <span class="text-sm text-slate-500 font-medium">I.G.V (18%):</span>
                                            <span class="text-sm font-bold text-slate-700 dark:text-slate-300">S/ <%=
                                                    fIgv %></span>
                                        </div>
                                        <div
                                            class="flex justify-between items-center bg-primary p-4 rounded-xl text-white mt-4 shadow-lg shadow-primary/20">
                                            <span class="text-sm font-bold uppercase tracking-wider">Total Venta:</span>
                                            <span class="text-xl font-black">S/ <%= fTotal %></span>
                                        </div>
                                        <div class="text-right text-[10px] text-slate-400 mt-1 uppercase font-semibold">
                                            Soles (PEN)
                                        </div>
                                    </div>
                                </div>

                                <!-- Bottom Info: Signature -->
                                <div
                                    class="mt-12 pt-8 border-t border-slate-100 dark:border-slate-800 flex flex-col items-center sm:items-end justify-center">
                                    <!-- Signature Area -->
                                    <div class="text-center min-w-[200px]">
                                        <div class="h-16 flex items-center justify-center">
                                            <p
                                                class="font-serif italic text-slate-400 font-semibold text-xl select-none">
                                                <%= usInfo.Nombres ? usInfo.Nombres.charAt(0)+'.' : '' %>
                                                    <%= usInfo.Apellidos || 'CARSIL' %>
                                            </p>
                                        </div>
                                        <div class="border-t border-slate-300 dark:border-slate-700 pt-2">
                                            <p
                                                class="text-[10px] font-bold text-slate-700 dark:text-slate-300 uppercase tracking-wide">
                                                Representante de Ventas</p>
                                            <p class="text-[9px] text-slate-400 font-medium uppercase mt-0.5">CARSIL
                                                EQUIPOS Y SERVICIOS S.A.C.</p>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </main>
                </div>
            </div>

            <script>
                // Configuración para el PDF
                window.facturaInfo = {
                    codigo: '<%= factura.Codigo %>',
                    fecha: '<%= fFechaEmision %>'
                };

                async function generatePDF() {
                    const btn = document.getElementById('btnDownloadPdf');
                    const originalText = btn.innerHTML;
                    const pageContainer = document.querySelector('.group\\/design-root');

                    try {
                        btn.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">refresh</span> Generando PDF...';
                        btn.disabled = true;

                        // Entrar a PDF mode (oculta botones, fuerza fondos blancos, ajusta estilos)
                        pageContainer.classList.add('pdf-mode');

                        // Pausa breve para aplicar estilos
                        await new Promise(r => setTimeout(r, 100));

                        const element = document.getElementById('factura-print-area');

                        // Capturar con alta fidelidad
                        const canvas = await html2canvas(element, {
                            scale: 1.5, // Resolución intermedia para evitar PDFs enormes
                            useCORS: true,
                            backgroundColor: '#ffffff',
                            logging: false,
                            windowWidth: 1024,
                            width: element.offsetWidth
                        });

                        // Restaurar vista
                        pageContainer.classList.remove('pdf-mode');

                        const imgData = canvas.toDataURL('image/jpeg', 0.95);

                        const { jsPDF } = window.jspdf;
                        const pdf = new jsPDF({
                            orientation: 'portrait',
                            unit: 'mm',
                            format: 'a4'
                        });

                        const pdfWidth = pdf.internal.pageSize.getWidth();
                        const pdfHeight = pdf.internal.pageSize.getHeight();

                        // Márgenes PDF (15mm)
                        const margin = 15;
                        const usableWidth = pdfWidth - (margin * 2);

                        const imgWidthPixels = canvas.width;
                        const imgHeightPixels = canvas.height;

                        // Relación de aspecto
                        const ratio = imgHeightPixels / imgWidthPixels;

                        // Tamaño final en mm (ancho fijo al de pagina útil, alto calculado por escala)
                        const printWidth = usableWidth;
                        const printHeight = printWidth * ratio;

                        // Si es más alto que una página, se añadirá el reajuste pero generalmente cuadra bien.
                        pdf.addImage(imgData, 'JPEG', margin, margin, printWidth, printHeight);

                        pdf.save(`Factura_${window.facturaInfo.codigo}.pdf`);

                        // Restaurar botón success
                        btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">check</span> ¡Descargado!';
                        setTimeout(() => {
                            btn.innerHTML = originalText;
                            btn.disabled = false;
                        }, 2000);

                    } catch (error) {
                        console.error('Error:', error);
                        pageContainer.classList.remove('pdf-mode');
                        btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">error</span> Falló';
                        setTimeout(() => {
                            btn.innerHTML = originalText;
                            btn.disabled = false;
                        }, 3000);
                        alert('Hubo un error al generar el PDF. Puedes probar a imprimir en Nativo como PDF.');
                    }
                }
            </script>
</body>

</html>