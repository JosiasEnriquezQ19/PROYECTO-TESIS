        fila.querySelector('.precio-nuevo').addEventListener('input', () => calcTotalNuevo(nid));
        fila.querySelector('.remove-nuevo').addEventListener('click', () => {
            if (confirm('¿Eliminar este producto?')) { fila.remove(); calcularTotales(); }
        });
    }

    function calcTotalNuevo(nid) {
        const f = document.querySelector(`[data-nuevo-id="${nid}"]`);
        if (!f) return;
        const t = (parseFloat(f.querySelector('.cantidad-nueva').value)||0) * (parseFloat(f.querySelector('.precio-nuevo').value)||0);
        f.querySelector('.total-producto').textContent = `S/ ${t.toFixed(2)}`;
        calcularTotales();
    }

    function actualizarProductoExistente(detalleId) {
        const f = document.querySelector(`[data-detalle-id="${detalleId}"]`);
        if (!f) return;
        const cant = parseFloat(f.querySelector('.cantidad-input')?.value)||0;
        const prec = parseFloat(f.querySelector('.precio-input')?.value)||0;
        const total = cant * prec;
        f.querySelector('.total-producto').textContent = `S/ ${total.toFixed(2)}`;
        const idx = productosModificados.findIndex(p => p.IdDetalleFactura == detalleId);
        const obj = { IdDetalleFactura: detalleId, Cantidad: cant, PrecioUnitario: prec, Total: total };
        idx >= 0 ? productosModificados[idx] = obj : productosModificados.push(obj);
        calcularTotales();
    }

    function eliminarProductoAdicional(detalleId) {
        if (!confirm('¿Eliminar este producto adicional?')) return;
        const f = document.querySelector(`[data-detalle-id="${detalleId}"]`);
        if (f && f.dataset.tipo === 'ADICIONAL') { f.remove(); productosEliminados.push(detalleId); calcularTotales(); }
    }

    function calcularTotales() {
        let sO = 0, sA = 0;
        document.querySelectorAll('[data-tipo="ORIGINAL"] .total-producto').forEach(el => { sO += parseFloat(el.textContent.replace('S/ ',''))||0; });
        document.querySelectorAll('[data-tipo="ADICIONAL"] .total-producto').forEach(el => {
            const f = el.closest('.producto-row');
            if (f && !productosEliminados.includes(f.dataset.detalleId)) sA += parseFloat(el.textContent.replace('S/ ',''))||0;
        });
        document.querySelectorAll('#nuevosProductosAdicionales .total-producto').forEach(el => { sA += parseFloat(el.textContent.replace('S/ ',''))||0; });
        const igvO=sO*0.18, tO=sO+igvO, igvA=sA*0.18, tA=sA+igvA;
        document.getElementById('subtotalOriginal').textContent   = `S/ ${sO.toFixed(2)}`;
        document.getElementById('igvOriginal').textContent        = `S/ ${igvO.toFixed(2)}`;
        document.getElementById('totalOriginal').textContent      = `S/ ${tO.toFixed(2)}`;
        document.getElementById('subtotalAdicionales').textContent= `S/ ${sA.toFixed(2)}`;
        document.getElementById('igvAdicionales').textContent     = `S/ ${igvA.toFixed(2)}`;
        document.getElementById('totalAdicionales').textContent   = `S/ ${tA.toFixed(2)}`;
        document.getElementById('totalFinal').textContent         = `S/ ${(tO+tA).toFixed(2)}`;
    }

    function actualizarInputsHidden() {
        const c = document.getElementById('productosModificadosHidden');
        c.innerHTML = '';
        productosModificados.forEach((p,i) => {
            c.innerHTML += `<input type="hidden" name="productosModificados[${i}][IdDetalleFactura]" value="${p.IdDetalleFactura}">
                            <input type="hidden" name="productosModificados[${i}][Cantidad]" value="${p.Cantidad}">
                            <input type="hidden" name="productosModificados[${i}][PrecioUnitario]" value="${p.PrecioUnitario}">`;
        });
        productosEliminados.forEach((id,i) => { c.innerHTML += `<input type="hidden" name="productosEliminados[${i}]" value="${id}">`; });
        document.querySelectorAll('#nuevosProductosAdicionales .producto-row').forEach((f,i) => {
            const sel=f.querySelector('.producto-select'), cant=f.querySelector('.cantidad-nueva'),
                  prec=f.querySelector('.precio-nuevo'), desc=f.querySelector('input[data-field="descripcion"]');
            if (sel && sel.value) {
                c.innerHTML += `<input type="hidden" name="nuevosProductos[${i}][IdProducto]" value="${sel.value}">
                                <input type="hidden" name="nuevosProductos[${i}][Cantidad]" value="${cant.value}">
                                <input type="hidden" name="nuevosProductos[${i}][PrecioUnitario]" value="${prec.value}">
                                <input type="hidden" name="nuevosProductos[${i}][DescripcionAdicional]" value="${desc?desc.value:''}">`;
            }
        });
    }

    async function validarYEnviarFormulario(e) {
        e.preventDefault();
        actualizarInputsHidden();
        if (!document.getElementById('Estado').value || !document.getElementById('IdCliente').value || !document.getElementById('FechaEmision').value) {
            alert('Complete todos los campos obligatorios.'); return;
        }
        for (const f of document.querySelectorAll('#nuevosProductosAdicionales .producto-row')) {
            const sel=f.querySelector('.producto-select'), cant=f.querySelector('.cantidad-nueva'), prec=f.querySelector('.precio-nuevo');
            if (!sel.value || !cant.value || cant.value<=0 || prec.value<0) { alert('Complete correctamente los productos adicionales.'); return; }
        }
        if (confirm('¿Actualizar esta factura?')) {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">progress_activity</span> Actualizando...';
            e.target.submit();
        }
    }

    // Auto-calcular fecha vencimiento
    const fpSelect = document.getElementById('FormaPago');
    const feInput  = document.getElementById('FechaEmision');
    const fvInput  = document.getElementById('FechaVencimiento');
    function calcFechaVenc() {
        const fp=fpSelect.value, fe=feInput.value;
        if (!fe) return;
        if (fp.startsWith('CREDITO_')) { const d=new Date(fe); d.setDate(d.getDate()+parseInt(fp.split('_')[1])); fvInput.value=d.toISOString().split('T')[0]; }
        else if (fp==='CONTADO') fvInput.value=fe;
    }
    fpSelect.addEventListener('change', calcFechaVenc);
    feInput.addEventListener('change', calcFechaVenc);

    // Actualizar badge estado
    document.getElementById('Estado').addEventListener('change', function() {
        const map = { PENDIENTE:'bg-amber-50 text-amber-700', PAGADA:'bg-emerald-50 text-emerald-700', VENCIDA:'bg-rose-50 text-rose-700', ANULADA:'bg-slate-100 text-slate-500' };
        const b = document.getElementById('estadoBadge');
        b.className = `inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider ${map[this.value]||'bg-slate-100 text-slate-500'}`;
        b.innerHTML = `<span class="material-symbols-outlined text-[14px]">flag</span>${this.value}`;
    });
});
</script>
