                        const data = await response.json();
                        productosDisponibles = data.productos || [];
                    }
                } catch (error) {
                    console.error('Error al cargar productos:', error);
                }
            }

            function agregarNuevoProducto() {
                if (productosDisponibles.length === 0) {
                    Swal.fire('Error', 'No hay productos disponibles. Asegúrese de que existan productos en el sistema.', 'error');
                    return;
                }

                contadorNuevosProductos++;
                const nuevoId = `nuevo_${contadorNuevosProductos}`;

                const nuevaFila = document.createElement('tr');
                nuevaFila.className = 'group hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors bg-blue-50/40 dark:bg-primary/5 producto-row';
                nuevaFila.dataset.nuevoId = nuevoId;
                nuevaFila.dataset.tipo = 'ADICIONAL';

                nuevaFila.innerHTML = `
            <td class="px-6 py-4 text-center">
                <div class="bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400 text-[10px] px-2 py-1 rounded font-bold uppercase inline-flex items-center"><span class="material-symbols-outlined text-[12px] mr-1">new_releases</span> Nuevo</div>
            </td>
            <td class="px-6 py-4">
                <select class="w-full rounded-md border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-sm focus:ring-primary mb-2 producto-select" data-nuevo-id="${nuevoId}" required>
                    <option value="">Seleccionar producto...</option>
                    ${productosDisponibles.map(p =>
                    `<option value="${p.IdProducto}" data-precio="${p.PrecioUnitario}" data-unidad="${p.UnidadMedida}">
                            ${p.Nombre} - ${p.Marca || ''} ${p.Modelo || ''}
                        </option>`
                ).join('')}
                </select>
                <input type="text" class="w-full border-transparent bg-transparent dark:text-slate-300 focus:ring-0 focus:border-b focus:border-primary p-1 text-xs italic" placeholder="Agregar descripción extra (opcional)" data-nuevo-id="${nuevoId}" data-field="descripcion">
            </td>
            <td class="px-6 py-4">
                <input type="number" class="w-full rounded-md border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-sm py-1 px-2 text-center cantidad-nueva focus:ring-primary" min="0.01" step="0.01" value="1" data-nuevo-id="${nuevoId}" required>
            </td>
            <td class="px-6 py-4 text-sm text-slate-600 dark:text-slate-400 text-center font-medium unidad-display">UNID</td>
            <td class="px-6 py-4 text-right">
                <input type="number" class="w-full text-right rounded-md border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-sm py-1 px-2 focus:ring-primary precio-nuevo" min="0" step="0.01" value="0.00" data-nuevo-id="${nuevoId}" required>
            </td>
            <td class="px-6 py-4 text-right text-sm font-bold text-slate-900 dark:text-white total-producto">S/ 0.00</td>
            <td class="px-6 py-4 text-center">
                <button type="button" class="text-slate-400 hover:text-red-500 transition-colors btn-remove-product" data-nuevo-id="${nuevoId}" title="Eliminar producto nuevo">
                    <span class="material-symbols-outlined text-[20px]">delete</span>
                </button>
            </td>
        `;

                document.getElementById('nuevosProductosAdicionales').appendChild(nuevaFila);

                // Agregando event listeners locales a la fila insertada
                const select = nuevaFila.querySelector('.producto-select');
                const cantidadInput = nuevaFila.querySelector('.cantidad-nueva');
                const precioInput = nuevaFila.querySelector('.precio-nuevo');
                const removeBtn = nuevaFila.querySelector('.btn-remove-product');

                select.addEventListener('change', function () {
                    const opt = this.options[this.selectedIndex];
                    if (opt.value) {
                        precioInput.value = parseFloat(opt.dataset.precio || 0).toFixed(2);
                        nuevaFila.querySelector('.unidad-display').textContent = opt.dataset.unidad || 'UND';
                        calcularTotalNuevoProducto(nuevoId);
                    }
                });

                cantidadInput.addEventListener('input', () => calcularTotalNuevoProducto(nuevoId));
                precioInput.addEventListener('input', () => calcularTotalNuevoProducto(nuevoId));

                removeBtn.addEventListener('click', async function () {
                    if (await liquidGlassConfirm('¿Eliminar esta fila nueva?')) {
                        nuevaFila.remove();
                        calcularTotales();
                    }
                });
            }

            function calcularTotalNuevoProducto(nuevoId) {
                const fila = document.querySelector(`[data-nuevo-id="${nuevoId}"]`);
                if (!fila) return;
                const cant = parseFloat(fila.querySelector('.cantidad-nueva').value) || 0;
                const prec = parseFloat(fila.querySelector('.precio-nuevo').value) || 0;
                const total = cant * prec;
                fila.querySelector('.total-producto').textContent = formatter.format(total).replace('PEN', 'S/');
                calcularTotales();
            }

            function actualizarProductoExistente(detalleId) {
                const fila = document.querySelector(`[data-detalle-id="${detalleId}"]`);
                if (!fila) return;

                const cant = parseFloat(fila.querySelector('.cantidad-input').value) || 0;
                const prec = parseFloat(fila.querySelector('.precio-input').value) || 0;
                const total = cant * prec;

                fila.querySelector('.total-producto').textContent = formatter.format(total).replace('PEN', 'S/');

                const idx = productosModificados.findIndex(p => p.IdDetalleFactura == detalleId);
                const obj = { IdDetalleFactura: detalleId, Cantidad: cant, PrecioUnitario: prec, Total: total };
                if (idx >= 0) productosModificados[idx] = obj;
                else productosModificados.push(obj);

                calcularTotales();
            }

            async function eliminarProductoAdicional(detalleId) {
                if (await liquidGlassConfirm('¿Está seguro de que desea eliminar este ítem de la factura original?')) {
                    const fila = document.querySelector(`[data-detalle-id="${detalleId}"]`);
                    if (fila && fila.dataset.tipo === 'ADICIONAL') {
                        fila.remove();
                        productosEliminados.push(detalleId);
                        calcularTotales();
                    }
                }
            }

            function calcularTotales() {
                let subOrig = 0, subAdic = 0;

                document.querySelectorAll('[data-tipo="ORIGINAL"] .total-producto').forEach(el => {
                    subOrig += parseFloat(el.textContent.replace(/[S/\s,]/g, '')) || 0;
                });

                document.querySelectorAll('[data-tipo="ADICIONAL"] .total-producto').forEach(el => {
                    const row = el.closest('tr');
                    if (row && !productosEliminados.includes(row.dataset.detalleId)) {
                        subAdic += parseFloat(el.textContent.replace(/[S/\s,]/g, '')) || 0;
                    }
                });

                const igvOrig = subOrig * 0.18;
                const igvAdic = subAdic * 0.18;

                document.getElementById('subtotalOriginal').textContent = formatter.format(subOrig).replace('PEN', 'S/');
                document.getElementById('igvOriginal').textContent = formatter.format(igvOrig).replace('PEN', 'S/');

                document.getElementById('subtotalAdicionales').textContent = formatter.format(subAdic).replace('PEN', 'S/');
                document.getElementById('igvAdicionales').textContent = formatter.format(igvAdic).replace('PEN', 'S/');

                const gTotal = (subOrig + igvOrig) + (subAdic + igvAdic);
                document.getElementById('totalFinal').textContent = formatter.format(gTotal).replace('PEN', 'S/');
            }

            async function validarYEnviarFormulario(e) {
                e.preventDefault();
                actualizarInputsHidden();

                const req = ['Estado', 'IdCliente', 'FechaEmision'];
                for (let id of req) {
                    if (!document.getElementById(id).value) {
                        Swal.fire('Atención', 'Por favor complete todos los datos básicos requeridos.', 'warning');
                        return;
                    }
                }

                const news = document.querySelectorAll('#nuevosProductosAdicionales .producto-row');
                for (let row of news) {
                    const select = row.querySelector('.producto-select');
                    const cant = row.querySelector('.cantidad-nueva');
                    const prec = row.querySelector('.precio-nuevo');
                    if (!select.value || !cant.value || cant.value <= 0 || prec.value < 0) {
                        Swal.fire('Atención', 'Verifique que los productos adicionales que agregó estén correctamente llenados.', 'warning');
                        return;
                    }
                }

                if (await liquidGlassConfirm('¿Actualizar esta factura con los montos e ítems especificados?')) {
                    const submitBtn = document.querySelector('button[type="submit"]');
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<span class="material-symbols-outlined animate-spin mr-2">refresh</span> Guardando...';
                    e.target.submit();
                }
            }

            function actualizarInputsHidden() {
                const c = document.getElementById('productosModificadosHidden');
                c.innerHTML = '';

                productosModificados.forEach((p, i) => {
                    c.innerHTML += `
                <input type="hidden" name="productosModificados[${i}][IdDetalleFactura]" value="${p.IdDetalleFactura}">
                <input type="hidden" name="productosModificados[${i}][Cantidad]" value="${p.Cantidad}">
                <input type="hidden" name="productosModificados[${i}][PrecioUnitario]" value="${p.PrecioUnitario}">
            `;
                });

                productosEliminados.forEach((id, i) => {
                    c.innerHTML += `<input type="hidden" name="productosEliminados[${i}]" value="${id}">`;
                });

                const news = document.querySelectorAll('#nuevosProductosAdicionales .producto-row');
                news.forEach((row, i) => {
                    const select = row.querySelector('.producto-select');
                    const cant = row.querySelector('.cantidad-nueva');
                    const prec = row.querySelector('.precio-nuevo');
                    const desc = row.querySelector('input[data-field="descripcion"]');

                    if (select.value) {
                        c.innerHTML += `
                    <input type="hidden" name="nuevosProductos[${i}][IdProducto]" value="${select.value}">
                    <input type="hidden" name="nuevosProductos[${i}][Cantidad]" value="${cant.value}">
                    <input type="hidden" name="nuevosProductos[${i}][PrecioUnitario]" value="${prec.value}">
                    <input type="hidden" name="nuevosProductos[${i}][DescripcionAdicional]" value="${desc.value}">
