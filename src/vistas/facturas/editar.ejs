                                <span class="material-symbols-outlined text-[20px]">notifications</span>
                            </button>
                        </div>
                        <div
                            class="bg-primary/10 border border-primary/20 rounded-full size-10 flex items-center justify-center overflow-hidden font-bold text-primary">
                            <%= user && user.Nombres ? user.Nombres.charAt(0) : 'U' %>
                        </div>
                    </div>
                </header>

                <main class="flex flex-1 justify-center py-8 relative">
                    <div class="layout-content-container flex flex-col w-full max-w-[1200px] flex-1 px-4 md:px-10">

