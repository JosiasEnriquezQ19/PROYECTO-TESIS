<!-- src/vistas/empresa/edit.ejs -->
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuración de Empresa - CARSIL</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: { "primary": "#3b4bc9", "background-light": "#f6f6f8" },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <link rel="stylesheet" href="/publico/css/layout.css?v=1772427290140">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .main-content { padding: 0 !important; background: #f6f6f8; }
    </style>
</head>

<body class="bg-[#f6f6f8] text-slate-900 font-display">
<div class="wrapper">
    <%- include("../parciales/sidebar") %>

    <div class="main-content" id="main-content">

        <!-- Top Nav -->
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-8 sticky top-0 z-10 shadow-sm">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-[#3b4bc9]">corporate_fare</span>
                <h2 class="text-lg font-bold text-slate-900">Configuración de Empresa</h2>
            </div>
            <div class="flex items-center gap-3">
                <div class="relative">
                    <span class="material-symbols-outlined p-2 text-slate-500 hover:bg-slate-100 rounded-full cursor-pointer transition-colors">notifications</span>
                    <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                </div>
                <div class="h-8 w-px bg-slate-200"></div>
                <div class="text-right hidden sm:block">
                    <p class="text-sm font-bold leading-none text-slate-900"><%= user && user.Nombres ? user.Nombres : 'Administrador' %></p>
                    <p class="text-xs text-slate-500 mt-0.5">Super Administrador</p>
                </div>
                <div class="w-9 h-9 rounded-full bg-[#3b4bc9]/10 flex items-center justify-center text-[#3b4bc9] text-sm font-bold border-2 border-[#3b4bc9]/20">
                    <%= user && user.Nombres ? user.Nombres.charAt(0).toUpperCase() : 'A' %>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <div class="max-w-5xl mx-auto p-8">

            <!-- Page Heading -->
            <div class="mb-8">
                <h3 class="text-2xl font-black text-slate-900 tracking-tight">Configuración Corporativa</h3>
                <p class="text-slate-500 mt-1">Configura la identidad corporativa, datos de contacto y parámetros financieros de tu organización.</p>
            </div>

            <!-- Flash messages -->
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="mb-6 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-emerald-500">check_circle</span>
                <span><%= success %></span>
            </div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="mb-6 flex items-center gap-3 bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-xl text-sm">
                <span class="material-symbols-outlined text-rose-500">error</span>
                <span><%= error %></span>
            </div>
            <% } %>

            <form action="/empresa/editar/<%= empresa.IdEmpresa %>" method="POST" enctype="multipart/form-data" class="space-y-8">

                <!-- Sección: Identidad Corporativa -->
                <section class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#3b4bc9]">branding_watermark</span>
                            <h4 class="text-base font-bold text-slate-900">Identidad Corporativa</h4>
                        </div>
                    </div>
                    <div class="p-6 grid grid-cols-1 md:grid-cols-12 gap-6">

                        <!-- Logo Upload -->
                        <div class="md:col-span-4 flex flex-col items-center justify-center p-6 border-2 border-dashed border-slate-200 rounded-xl bg-slate-50/50 hover:border-[#3b4bc9]/50 transition-all group cursor-pointer" onclick="document.getElementById('Logo').click()">
                            <div class="w-full aspect-video bg-white rounded-lg flex items-center justify-center overflow-hidden shadow-inner">
                                <% if (empresa.Logo) { %>
                                <img src="/empresa/logo/<%= empresa.IdEmpresa %>" alt="Logo de la empresa" class="w-full h-full object-contain p-2">
                                <% } else { %>
                                <span class="material-symbols-outlined text-5xl text-slate-300">image</span>
                                <% } %>
                            </div>
                            <button class="mt-4 flex items-center gap-1.5 text-[#3b4bc9] font-bold text-sm hover:underline" type="button">
                                <span class="material-symbols-outlined text-base">upload</span>
                                Subir Nuevo Logo
                            </button>
                            <p class="text-xs text-slate-400 mt-1.5">Recomendado: 400×400px, PNG o SVG</p>
                            <input type="file" id="Logo" name="Logo" accept="image/*" class="hidden">
                        </div>

                        <!-- Identity Fields -->
                        <div class="md:col-span-8 space-y-4">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="space-y-1.5">
                                    <label class="text-sm font-bold text-slate-700" for="Nombre">Razón Social <span class="text-red-500">*</span></label>
                                    <div class="relative">
                                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none">business</span>
                                        <input type="text" id="Nombre" name="Nombre" value="<%= empresa.Nombre || '' %>" required placeholder="Ej: CARSIL Automotriz S.A.C"
                                            class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                    </div>
                                </div>
                                <div class="space-y-1.5">
                                    <label class="text-sm font-bold text-slate-700" for="RUC">RUC <span class="text-red-500">*</span></label>
                                    <div class="relative">
                                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none">badge</span>
                                        <input type="text" id="RUC" name="RUC" value="<%= empresa.RUC || '' %>" required maxlength="11" placeholder="20123456789"
                                            class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                    </div>
                                </div>
                            </div>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="space-y-1.5">
                                    <label class="text-sm font-bold text-slate-700" for="NombreComercial">Nombre Comercial</label>
                                    <div class="relative">
                                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none">store</span>
                                        <input type="text" id="NombreComercial" name="NombreComercial" value="<%= empresa.NombreComercial || '' %>" placeholder="CARSIL Perú"
                                            class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                    </div>
                                </div>
                                <div class="space-y-1.5">
                                    <label class="text-sm font-bold text-slate-700" for="Estado">Estado</label>
                                    <div class="relative">
                                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none">toggle_on</span>
                                        <select id="Estado" name="Estado"
                                            class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm appearance-none cursor-pointer">
                                            <option value="1" <%= empresa.Estado == 1 ? 'selected' : '' %>>Activo</option>
                                            <option value="0" <%= empresa.Estado == 0 ? 'selected' : '' %>>Inactivo</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Sección: Ubicación y Contacto -->
                <section class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#3b4bc9]">location_on</span>
                            <h4 class="text-base font-bold text-slate-900">Ubicación y Contacto</h4>
                        </div>
                    </div>
                    <div class="p-6 space-y-4">
                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-slate-700" for="Direccion">Dirección Fiscal <span class="text-red-500">*</span></label>
                            <div class="relative">
                                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none">map</span>
                                <input type="text" id="Direccion" name="Direccion" value="<%= empresa.Direccion || '' %>" required placeholder="Av. Principal 123, Urb. Los Olivos, Lima"
                                    class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                            </div>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-slate-700" for="Telefono">Teléfono</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none">call</span>
                                    <input type="tel" id="Telefono" name="Telefono" value="<%= empresa.Telefono || '' %>" maxlength="20" placeholder="(01) 445 1234"
                                        class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                            <div class="space-y-1.5">
                                <label class="text-sm font-bold text-slate-700" for="Celular">Celular</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none">phone_iphone</span>
                                    <input type="tel" id="Celular" name="Celular" value="<%= empresa.Celular || '' %>" maxlength="20" placeholder="987 654 321"
                                        class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                            <div class="sm:col-span-2 space-y-1.5">
                                <label class="text-sm font-bold text-slate-700" for="Email">Correo Corporativo</label>
                                <div class="relative">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none">mail</span>
                                    <input type="email" id="Email" name="Email" value="<%= empresa.Email || '' %>" maxlength="100" placeholder="contacto@carsil.com.pe"
                                        class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all text-sm">
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Sección: Información Financiera -->
                <section class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#3b4bc9]">account_balance</span>
                            <h4 class="text-base font-bold text-slate-900">Información Financiera</h4>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="p-4 rounded-xl border border-slate-200 space-y-4">
                                <div class="flex justify-between items-center">
                                    <span class="text-xs font-bold uppercase text-slate-400 tracking-wider">Cuenta Bancaria Principal</span>
                                    <span class="bg-green-100 text-green-700 text-[10px] font-bold px-2 py-0.5 rounded-full uppercase"><%= empresa.Estado == 1 ? 'Activo' : 'Inactivo' %></span>
                                </div>
                                <div class="space-y-3">
                                    <div class="space-y-1.5">
                                        <label class="text-xs font-bold text-slate-600" for="NombreCuentaBancaria">Titular de la Cuenta</label>
                                        <input type="text" id="NombreCuentaBancaria" name="NombreCuentaBancaria" value="<%= empresa.NombreCuentaBancaria || '' %>" maxlength="100" placeholder="CARSIL AUTOMOTRIZ SAC"
                                            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all">
                                    </div>
                                    <div class="space-y-1.5">
                                        <label class="text-xs font-bold text-slate-600" for="CuentaBancaria">Banco y Número de Cuenta</label>
                                        <input type="text" id="CuentaBancaria" name="CuentaBancaria" value="<%= empresa.CuentaBancaria || '' %>" maxlength="100" placeholder="BCP - 193-4567890-0-12"
                                            class="w-full px-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all">
                                    </div>
                                </div>
                            </div>
                            <div class="p-4 rounded-xl border-2 border-dashed border-slate-200 flex flex-col items-center justify-center text-slate-400 gap-2 cursor-pointer hover:bg-slate-50 transition-colors">
                                <span class="material-symbols-outlined text-3xl">add_circle</span>
                                <span class="text-sm font-semibold">Agregar Cuenta Secundaria</span>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Sección: Preferencias -->
                <section class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
                    <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-[#3b4bc9]">description</span>
                            <h4 class="text-base font-bold text-slate-900">Preferencias</h4>
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="space-y-1.5">
                            <label class="text-sm font-bold text-slate-700" for="TextoPresentacion">Texto de Presentación en Proformas</label>
                            <p class="text-xs text-slate-500">Este texto aparecerá en la parte superior de todas las proformas generadas.</p>
                            <textarea id="TextoPresentacion" name="TextoPresentacion" rows="4" maxlength="500"
                                placeholder="Estimado cliente, es un gusto saludarlo. A continuación presentamos nuestra mejor propuesta económica..."
                                class="w-full p-4 bg-white border border-slate-200 rounded-lg focus:ring-2 focus:ring-[#3b4bc9]/20 focus:border-[#3b4bc9] outline-none transition-all resize-none text-sm mt-2"><%= empresa.TextoPresentacion || '' %></textarea>
                        </div>
                    </div>
                </section>

                <!-- Form Actions -->
                <div class="flex items-center justify-end gap-4 py-6 border-t border-slate-200">
                    <a href="/empresa" class="px-6 py-2.5 text-sm font-bold text-slate-600 hover:bg-slate-100 rounded-lg transition-colors">
                        Descartar cambios
                    </a>
                    <button type="submit" class="px-8 py-2.5 bg-[#3b4bc9] hover:bg-[#3b4bc9]/90 text-white rounded-lg text-sm font-bold shadow-lg shadow-[#3b4bc9]/30 transition-all flex items-center gap-2">
                        <span class="material-symbols-outlined text-lg">save</span>
                        Guardar Configuración
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>
<script src="/publico/js/layout.js?v=1772427290140"></script>
</body>

</html>