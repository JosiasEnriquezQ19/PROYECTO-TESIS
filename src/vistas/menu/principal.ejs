<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - CARSIL Gestión de Proformas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/publico/css/layout.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* ========================================
           DASHBOARD STYLES
           ======================================== */

        /* Top Navbar */
        .dash-navbar {
            height: 64px;
            background: var(--bg-card);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .dash-nav-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .dash-nav-search {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg-page);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 8px 16px;
            width: 280px;
            margin-left: 60px;
        }

        .dash-nav-search i {
            color: var(--text-muted);
            font-size: 0.875rem;
        }

        .dash-nav-search input {
            border: none;
            background: transparent;
            outline: none;
            font-family: inherit;
            font-size: 0.8125rem;
            color: var(--text-primary);
            width: 100%;
        }

        .dash-nav-search input::placeholder {
            color: var(--text-muted);
        }

        .dash-nav-right {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .dash-nav-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.15s ease;
        }

        .dash-nav-icon:hover {
            background: var(--primary-light);
            color: var(--primary);
            border-color: var(--primary);
        }

        .dash-nav-user {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 4px 12px 4px 4px;
            border: 1px solid var(--border);
            border-radius: 10px;
            cursor: pointer;
        }

        .dash-nav-avatar {
            width: 34px;
            height: 34px;
            background: var(--primary);
            color: #fff;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.8125rem;
        }

        .dash-nav-user-info {
            line-height: 1.2;
        }

        .dash-nav-user-name {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .dash-nav-user-role {
            font-size: 0.625rem;
            color: var(--text-muted);
        }

        /* Page Content */
        .dash-content {
            padding: 28px 32px;
        }

        /* Page Header */
        .dash-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 24px;
        }

        .dash-title {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.5px;
        }

        .dash-date-picker {
            display: flex;
            align-items: center;
            gap: 8px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 8px 16px;
            font-size: 0.8125rem;
            color: var(--text-secondary);
            cursor: pointer;
        }

        .dash-date-picker i {
            color: var(--text-muted);
        }

        /* ========================================
           STAT CARDS ROW
           ======================================== */
        .stat-cards-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .stat-card-v2 {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px 22px;
            transition: box-shadow 0.2s ease;
        }

        .stat-card-v2:hover {
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
        }

        .stat-card-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 12px;
        }

        .stat-card-label {
            font-size: 0.8125rem;
            font-weight: 500;
            color: var(--text-secondary);
        }

        .stat-card-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--primary-light);
            color: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.125rem;
        }

        .stat-card-icon.green {
            background: var(--success-light);
            color: var(--success);
        }

        .stat-card-icon.purple {
            background: var(--purple-light);
            color: var(--purple);
        }

        .stat-card-icon.amber {
            background: var(--warning-light);
            color: var(--warning);
        }

        .stat-card-row {
            display: flex;
            align-items: baseline;
            gap: 10px;
            margin-bottom: 6px;
        }

        .stat-card-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1;
        }

        .stat-card-trend {
            font-size: 0.6875rem;
            font-weight: 600;
            padding: 2px 6px;
            border-radius: 4px;
            display: flex;
            align-items: center;
            gap: 2px;
        }

        .stat-card-trend.up {
            background: var(--success-light);
            color: var(--success);
        }

        .stat-card-trend.down {
            background: var(--danger-light);
            color: var(--danger);
        }

        .stat-card-sub {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* ========================================
           CHARTS ROW
           ======================================== */
        .charts-row {
            display: grid;
            grid-template-columns: 1.5fr 1fr;
            gap: 16px;
            margin-bottom: 24px;
        }

        .chart-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 24px;
        }

        .chart-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }

        .chart-card-title {
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .chart-card-subtitle {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .chart-filter-btn {
            display: flex;
            align-items: center;
            gap: 4px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 6px 12px;
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--text-secondary);
            cursor: pointer;
        }

        .chart-container {
            position: relative;
            height: 280px;
        }

        .chart-legend-custom {
            display: flex;
            gap: 16px;
            margin-bottom: 12px;
        }

        .chart-legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.75rem;
            color: var(--text-secondary);
        }

        .legend-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        /* ========================================
           RECENT TABLE
           ======================================== */
        .table-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 24px;
        }

        .table-card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
        }

        .table-card-title {
            font-size: 0.9375rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        .table-header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .table-search {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--bg-page);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 6px 12px;
            width: 200px;
        }

        .table-search i {
            color: var(--text-muted);
            font-size: 0.8125rem;
        }

        .table-search input {
            border: none;
            background: transparent;
            outline: none;
            font-family: inherit;
            font-size: 0.75rem;
            width: 100%;
            color: var(--text-primary);
        }

        .table-search input::placeholder {
            color: var(--text-muted);
        }

        .sort-btn {
            display: flex;
            align-items: center;
            gap: 4px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 6px 12px;
            font-size: 0.75rem;
            color: var(--text-secondary);
            cursor: pointer;
        }

        .dash-table {
            width: 100%;
            border-collapse: collapse;
        }

        .dash-table thead th {
            text-align: left;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.3px;
            padding: 10px 12px;
            border-bottom: 1px solid var(--border);
        }

        .dash-table tbody td {
            padding: 12px;
            font-size: 0.8125rem;
            color: var(--text-primary);
            border-bottom: 1px solid var(--border-light);
            vertical-align: middle;
        }

        .dash-table tbody tr:last-child td {
            border-bottom: none;
        }

        .dash-table tbody tr:hover {
            background: var(--bg-page);
        }

        .table-id {
            font-weight: 600;
            color: var(--text-primary);
        }

        .table-badge {
            font-size: 0.6875rem;
            font-weight: 500;
            padding: 3px 10px;
            border-radius: 20px;
        }

        .table-badge.pending {
            background: var(--warning-light);
            color: var(--warning);
        }

        .table-badge.completed {
            background: var(--success-light);
            color: var(--success);
        }

        .table-badge.cancelled {
            background: var(--danger-light);
            color: var(--danger);
        }

        .table-total {
            font-weight: 600;
            color: var(--text-primary);
        }

        /* ========================================
           RESPONSIVE
           ======================================== */
        @media (max-width: 1024px) {
            .stat-cards-row {
                grid-template-columns: repeat(2, 1fr);
            }

            .charts-row {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .dash-content {
                padding: 16px;
            }

            .stat-cards-row {
                grid-template-columns: 1fr;
            }

            .dash-navbar {
                padding: 0 16px;
            }

            .dash-nav-search {
                display: none;
            }

            .dash-nav-user-info {
                display: none;
            }

            .dash-header {
                flex-direction: column;
                gap: 12px;
                align-items: flex-start;
            }

            .table-header-actions {
                flex-direction: column;
                gap: 8px;
            }

            .table-search {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <%- include("../parciales/sidebar") %>

            <div class="main-content" id="main-content">
                <!-- Top Navbar -->
                <div class="dash-navbar">
                    <div class="dash-nav-left">
                        <div class="dash-nav-search">
                            <i class="bi bi-search"></i>
                            <input type="text" placeholder="Buscar proformas, clientes...">
                        </div>
                    </div>
                    <div class="dash-nav-right">
                        <button class="dash-nav-icon" title="Atajos">
                            <i class="bi bi-command"></i>
                        </button>
                        <button class="dash-nav-icon" title="Ayuda">
                            <i class="bi bi-question-circle"></i>
                        </button>
                        <div class="dash-nav-user">
                            <div class="dash-nav-avatar">
                                <%= user && user.Nombres ? user.Nombres.charAt(0) : 'A' %>
                            </div>
                            <div class="dash-nav-user-info">
                                <div class="dash-nav-user-name">
                                    <%= user && user.Nombres ? user.Nombres : 'Admin' %>
                                </div>
                                <div class="dash-nav-user-role">Administrador</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Dashboard Content -->
                <div class="dash-content">
                    <!-- Page Header -->
                    <div class="dash-header">
                        <h1 class="dash-title">Resumen General</h1>
                        <div class="dash-date-picker" id="dateDisplay">
                            <i class="bi bi-calendar3"></i>
                            <span id="dateRangeText"></span>
                            <i class="bi bi-chevron-down" style="font-size:0.625rem"></i>
                        </div>
                    </div>

                    <!-- Stat Cards -->
                    <div class="stat-cards-row">
                        <div class="stat-card-v2">
                            <div class="stat-card-top">
                                <span class="stat-card-label">Total Clientes</span>
                                <div class="stat-card-icon">
                                    <i class="bi bi-people"></i>
                                </div>
                            </div>
                            <div class="stat-card-row">
                                <span class="stat-card-value"
                                    data-count="<%= typeof estadisticas !== 'undefined' && estadisticas.clientes ? estadisticas.clientes : 0 %>">
                                    <%= typeof estadisticas !=='undefined' && estadisticas.clientes ?
                                        estadisticas.clientes : 0 %>
                                </span>
                                <span class="stat-card-trend up"><i class="bi bi-arrow-up-short"></i>4.9%</span>
                            </div>
                            <span class="stat-card-sub">Registrados en el sistema</span>
                        </div>

                        <div class="stat-card-v2">
                            <div class="stat-card-top">
                                <span class="stat-card-label">Proformas</span>
                                <div class="stat-card-icon green">
                                    <i class="bi bi-file-earmark-text"></i>
                                </div>
                            </div>
                            <div class="stat-card-row">
                                <span class="stat-card-value"
                                    data-count="<%= typeof estadisticas !== 'undefined' && estadisticas.proformas ? estadisticas.proformas : 0 %>">
                                    <%= typeof estadisticas !=='undefined' && estadisticas.proformas ?
                                        estadisticas.proformas : 0 %>
                                </span>
                                <span class="stat-card-trend up"><i class="bi bi-arrow-up-short"></i>7.5%</span>
                            </div>
                            <span class="stat-card-sub">Total generadas</span>
                        </div>

                        <div class="stat-card-v2">
                            <div class="stat-card-top">
                                <span class="stat-card-label">Productos</span>
                                <div class="stat-card-icon purple">
                                    <i class="bi bi-box-seam"></i>
                                </div>
                            </div>
                            <div class="stat-card-row">
                                <span class="stat-card-value"
                                    data-count="<%= typeof estadisticas !== 'undefined' && estadisticas.productos ? estadisticas.productos : 0 %>">
                                    <%= typeof estadisticas !=='undefined' && estadisticas.productos ?
                                        estadisticas.productos : 0 %>
                                </span>
                                <span class="stat-card-trend down"><i class="bi bi-arrow-down-short"></i>6.0%</span>
                            </div>
                            <span class="stat-card-sub">En catalogo activo</span>
                        </div>

                        <div class="stat-card-v2">
                            <div class="stat-card-top">
                                <span class="stat-card-label">Empleados Activos</span>
                                <div class="stat-card-icon amber">
                                    <i class="bi bi-person-badge"></i>
                                </div>
                            </div>
                            <div class="stat-card-row">
                                <span class="stat-card-value"
                                    data-count="<%= typeof estadisticas !== 'undefined' && estadisticas.empleados ? estadisticas.empleados : 0 %>">
                                    <%= typeof estadisticas !=='undefined' && estadisticas.empleados ?
                                        estadisticas.empleados : 0 %>
                                </span>
                                <span class="stat-card-trend up"><i class="bi bi-arrow-up-short"></i>2.1%</span>
                            </div>
                            <span class="stat-card-sub">Nomina del personal</span>
                        </div>
                    </div>

                    <!-- Charts Row -->
                    <div class="charts-row">
                        <!-- Revenue / Proformas Analytics -->
                        <div class="chart-card">
                            <div class="chart-card-header">
                                <div>
                                    <div class="chart-card-title">Actividad de Proformas</div>
                                </div>
                                <button class="chart-filter-btn">
                                    Esta Semana <i class="bi bi-chevron-down" style="font-size:0.625rem"></i>
                                </button>
                            </div>
                            <div class="chart-container">
                                <canvas id="barChart"></canvas>
                            </div>
                        </div>

                        <!-- Income Chart -->
                        <div class="chart-card">
                            <div class="chart-card-header">
                                <div>
                                    <div class="chart-card-title">Distribucion por Modulo</div>
                                    <div class="chart-card-subtitle">Registros activos en cada seccion</div>
                                </div>
                            </div>
                            <div class="chart-legend-custom">
                                <div class="chart-legend-item">
                                    <span class="legend-dot" style="background: var(--primary)"></span>
                                    Clientes
                                </div>
                                <div class="chart-legend-item">
                                    <span class="legend-dot" style="background: var(--text-primary)"></span>
                                    Productos
                                </div>
                            </div>
                            <div class="chart-container">
                                <canvas id="barChartIncome"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Orders / Proformas Table -->
                    <div class="table-card">
                        <div class="table-card-header">
                            <span class="table-card-title">Proformas Recientes</span>
                            <div class="table-header-actions">
                                <div class="table-search">
                                    <i class="bi bi-search"></i>
                                    <input type="text" placeholder="Buscar" id="tableSearchInput">
                                </div>
                                <button class="sort-btn">
                                    <i class="bi bi-filter"></i>
                                    Ordenar
                                    <i class="bi bi-chevron-down" style="font-size:0.625rem"></i>
                                </button>
                            </div>
                        </div>
                        <table class="dash-table" id="proformasTable">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Fecha</th>
                                    <th>Cliente</th>
                                    <th>Productos</th>
                                    <th>Estado</th>
                                    <th>Items</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span class="table-id">#PRF-001</span></td>
                                    <td>
                                        <%= new Date().toLocaleDateString('es-PE', { day: '2-digit' , month: 'short' ,
                                            year: 'numeric' }) %>
                                    </td>
                                    <td>Cliente General</td>
                                    <td>Equipos, Servicios</td>
                                    <td><span class="table-badge pending">Pendiente</span></td>
                                    <td>2 Items</td>
                                    <td><span class="table-total">S/ 1,250.00</span></td>
                                </tr>
                                <tr>
                                    <td><span class="table-id">#PRF-002</span></td>
                                    <td>
                                        <%= new Date().toLocaleDateString('es-PE', { day: '2-digit' , month: 'short' ,
                                            year: 'numeric' }) %>
                                    </td>
                                    <td>Empresa SAC</td>
                                    <td>Repuestos</td>
                                    <td><span class="table-badge completed">Completado</span></td>
                                    <td>3 Items</td>
                                    <td><span class="table-total">S/ 3,480.00</span></td>
                                </tr>
                                <tr>
                                    <td><span class="table-id">#PRF-003</span></td>
                                    <td>
                                        <%= new Date().toLocaleDateString('es-PE', { day: '2-digit' , month: 'short' ,
                                            year: 'numeric' }) %>
                                    </td>
                                    <td>Distribuidora Lima</td>
                                    <td>Maquinaria</td>
                                    <td><span class="table-badge completed">Completado</span></td>
                                    <td>1 Item</td>
                                    <td><span class="table-total">S/ 8,900.00</span></td>
                                </tr>
                                <tr>
                                    <td><span class="table-id">#PRF-004</span></td>
                                    <td>
                                        <%= new Date().toLocaleDateString('es-PE', { day: '2-digit' , month: 'short' ,
                                            year: 'numeric' }) %>
                                    </td>
                                    <td>Constructora Norte</td>
                                    <td>Herramientas</td>
                                    <td><span class="table-badge cancelled">Anulado</span></td>
                                    <td>5 Items</td>
                                    <td><span class="table-total">S/ 2,150.00</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
    </div>

    <script src="/publico/js/layout.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Date display
            const now = new Date();
            const dateStart = new Date(now);
            dateStart.setDate(dateStart.getDate() - 30);
            const fmt = { month: 'short', day: 'numeric', year: 'numeric' };
            document.getElementById('dateRangeText').textContent =
                dateStart.toLocaleDateString('es-PE', fmt) + ' - ' + now.toLocaleDateString('es-PE', fmt);

            // Counter animation
            document.querySelectorAll('.stat-card-value').forEach(el => {
                const target = parseInt(el.dataset.count) || 0;
                if (target === 0) return;
                let current = 0;
                const step = Math.max(Math.ceil(target / 40), 1);
                el.textContent = '0';
                const timer = setInterval(() => {
                    current += step;
                    if (current >= target) { current = target; clearInterval(timer); }
                    el.textContent = current;
                }, 30);
            });

            // ========================================
            // BAR CHART - Proformas Activity
            // ========================================
            const primary = '#3B49DF';
            const primaryLight = '#eef0fd';
            const barCtx = document.getElementById('barChart').getContext('2d');
            new Chart(barCtx, {
                type: 'bar',
                data: {
                    labels: ['Lun', 'Mar', 'Mie', 'Jue', 'Vie', 'Sab', 'Dom'],
                    datasets: [{
                        label: 'Proformas',
                        data: [12, 19, 8, 22, 15, 10, 5],
                        backgroundColor: function (context) {
                            const chart = context.chart;
                            const { ctx, chartArea } = chart;
                            if (!chartArea) return primary;
                            const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
                            gradient.addColorStop(0, primary);
                            gradient.addColorStop(1, '#5b67e8');
                            return gradient;
                        },
                        borderRadius: 6,
                        borderSkipped: false,
                        barPercentage: 0.6,
                        categoryPercentage: 0.7,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1A1A2E',
                            titleFont: { family: 'Inter', size: 12 },
                            bodyFont: { family: 'Inter', size: 11 },
                            padding: 10,
                            cornerRadius: 8,
                            displayColors: false,
                            callbacks: {
                                label: function (context) {
                                    return 'S/ ' + (context.raw * 1250).toLocaleString();
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                font: { family: 'Inter', size: 11 },
                                color: '#9CA3AF',
                                callback: v => v + 'k'
                            },
                            grid: { color: '#F0F0F0', drawBorder: false },
                            border: { display: false }
                        },
                        x: {
                            ticks: {
                                font: { family: 'Inter', size: 11, weight: 500 },
                                color: '#6B7280'
                            },
                            grid: { display: false },
                            border: { display: false }
                        }
                    }
                }
            });

            // ========================================
            // BAR CHART - Distribution by Module
            // ========================================
            const clientesVal = parseInt('<%= typeof estadisticas !== "undefined" && estadisticas.clientes ? estadisticas.clientes : 0 %>') || 0;
            const proformasVal = parseInt('<%= typeof estadisticas !== "undefined" && estadisticas.proformas ? estadisticas.proformas : 0 %>') || 0;
            const productosVal = parseInt('<%= typeof estadisticas !== "undefined" && estadisticas.productos ? estadisticas.productos : 0 %>') || 0;
            const empleadosVal = parseInt('<%= typeof estadisticas !== "undefined" && estadisticas.empleados ? estadisticas.empleados : 0 %>') || 0;

            const incomeCtx = document.getElementById('barChartIncome').getContext('2d');
            new Chart(incomeCtx, {
                type: 'bar',
                data: {
                    labels: ['Clientes', 'Proformas', 'Productos', 'Empleados'],
                    datasets: [
                        {
                            label: 'Registros',
                            data: [clientesVal, proformasVal, productosVal, empleadosVal],
                            backgroundColor: primary,
                            borderRadius: 4,
                            barPercentage: 0.5,
                            categoryPercentage: 0.7,
                        },
                        {
                            label: 'Meta',
                            data: [50, 30, 100, 20],
                            backgroundColor: '#1A1A2E',
                            borderRadius: 4,
                            barPercentage: 0.5,
                            categoryPercentage: 0.7,
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1A1A2E',
                            titleFont: { family: 'Inter', size: 12 },
                            bodyFont: { family: 'Inter', size: 11 },
                            padding: 10,
                            cornerRadius: 8,
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                font: { family: 'Inter', size: 11 },
                                color: '#9CA3AF'
                            },
                            grid: { color: '#F0F0F0', drawBorder: false },
                            border: { display: false }
                        },
                        x: {
                            ticks: {
                                font: { family: 'Inter', size: 11, weight: 500 },
                                color: '#6B7280'
                            },
                            grid: { display: false },
                            border: { display: false }
                        }
                    }
                }
            });

            // Table search
            const searchInput = document.getElementById('tableSearchInput');
            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    const val = this.value.toLowerCase();
                    document.querySelectorAll('#proformasTable tbody tr').forEach(row => {
                        row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
                    });
                });
            }
        });
    </script>
</body>

</html>